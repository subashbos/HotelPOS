<Window x:Class="HotelPOS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authentication - Hotel POS"
        Height="500" Width="400"
        MinHeight="400" MinWidth="350"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F9">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBrush" Color="#173F5F"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#00A896"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#D8DFEA"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding"         Value="12,14"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1A2533"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding"         Value="12,14"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1A2533"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,14"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#008A7B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="32" Padding="32">
            <StackPanel VerticalAlignment="Center">
                
                <!-- Logo / Header -->
                <TextBlock Text="Hotel POS"
                           FontSize="28" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Sign in to your account"
                           FontSize="14" Foreground="#5F6B7A"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- Username Form -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#1A2533" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,16" KeyDown="Input_KeyDown"/>

                <!-- Password Form -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#1A2533" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,24" KeyDown="Input_KeyDown"/>

                <!-- Error Indicator -->
                <TextBlock x:Name="ErrorText" Text="Invalid credentials" Foreground="#D32F2F" FontSize="13" 
                           Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <!-- Action -->
                <Button x:Name="LoginButton" Content="Log In" Click="Login_Click"/>
                
                <TextBlock Text="Requires local DB active" FontSize="11" Foreground="#A2B1C2" HorizontalAlignment="Center" Margin="0,24,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
