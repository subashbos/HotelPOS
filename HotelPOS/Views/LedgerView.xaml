<UserControl x:Class="HotelPOS.Views.LedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctrl="clr-namespace:HotelPOS.Controls"
             mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="1400">
    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="14,10"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="44"/>
            
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
                <Trigger Property="IsSelected"  Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Hero Header -->
        <Border Background="{DynamicResource HeaderBrush}" Padding="32,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📒  Revenue Ledger" FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Daily income summary with running balance." Margin="0,6,0,0" FontSize="13" Foreground="#BDD5E7"/>
                </StackPanel>
                <!-- Summary badges -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource SecondaryBrush}" CornerRadius="20" Padding="18,10" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock x:Name="TotalRevBadge" Text="Rs. 0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Period Revenue" FontSize="11" Foreground="#BDD5E7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="20" Padding="18,10">
                        <StackPanel>
                            <TextBlock x:Name="TotalOrdersBadge" Text="0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Orders" FontSize="11" Foreground="#A0DDD4" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="From:" FontSize="13" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="FromDate" Width="150" SelectedDateChanged="Filter_Changed" FontSize="13" Padding="8,6"/>
                <TextBlock Text="To:" FontSize="13" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="20,0,8,0"/>
                <DatePicker x:Name="ToDate" Width="150" SelectedDateChanged="Filter_Changed" FontSize="13" Padding="8,6"/>
                <Button Content="  All Time" Click="AllTime_Click"
                        Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="16,8" FontSize="13" Cursor="Hand" Margin="20,0,0,0"/>
                <Button Content="↻  Refresh" Click="Refresh_Click"
                        Background="{DynamicResource PrimaryBrush}" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="10,0,0,0"/>
                <Button Content="📤  Export Excel" Click="Export_Click"
                        Background="{DynamicResource SuccessBrush}" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Ledger DataGrid -->
        <Border Grid.Row="2" Margin="24" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="LedgerGrid"
                          Style="{StaticResource PremiumGrid}"
                          ItemsSource="{Binding LedgerEntries}">
                    <DataGrid.Columns>
                    <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60"/>
                        <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd MMM yyyy}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"       Value="14,0"/>
                                    <Setter Property="FontWeight"    Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="ORDERS" Binding="{Binding OrderCount}" Width="100"/>
                        <DataGridTemplateColumn Header="GROSS REVENUE" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GrossRevenue, StringFormat=Rs.{0:N2}}"
                                               FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                               Padding="14,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="GST COLLECTED" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GstAmount, StringFormat=Rs.{0:N2}}"
                                               Foreground="#E67E22"
                                               Padding="14,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="NET INCOME" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NetIncome, StringFormat=Rs.{0:N2}}"
                                               Padding="14,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="RUNNING BALANCE" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RunningBalance, StringFormat=Rs.{0:N2}}"
                                                   FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <ctrl:PaginationControl x:Name="LedgerPager" Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
