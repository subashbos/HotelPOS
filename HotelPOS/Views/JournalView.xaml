<UserControl x:Class="HotelPOS.Views.JournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctrl="clr-namespace:HotelPOS.Controls"
             mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="1400">
    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="14,10"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="44"/>
            
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
                <Trigger Property="IsSelected"  Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"           Value="14,0"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero Header -->
        <Border Background="{DynamicResource HeaderBrush}" Padding="32,22">
            <StackPanel>
                <TextBlock Text="📓  Transaction Journal" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Full transaction log with itemized order detail." Margin="0,6,0,0" FontSize="13" Foreground="#BDD5E7"/>
            </StackPanel>
        </Border>

        <!-- Filter Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="From:" FontSize="13" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="FromDate" Width="150" SelectedDateChanged="Filter_Changed" FontSize="13" Padding="8,6"/>
                <TextBlock Text="To:"   FontSize="13" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="20,0,8,0"/>
                <DatePicker x:Name="ToDate"   Width="150" SelectedDateChanged="Filter_Changed" FontSize="13" Padding="8,6"/>
                <TextBlock Text="Table:" FontSize="13" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="20,0,8,0"/>
                <ComboBox x:Name="TableFilter" Width="130" SelectionChanged="Filter_Changed" FontSize="13" Padding="8,6">
                    <ComboBoxItem Content="All Tables" IsSelected="True"/>
                    <ComboBoxItem Content="Table 1" Tag="1"/>
                    <ComboBoxItem Content="Table 2" Tag="2"/>
                    <ComboBoxItem Content="Table 3" Tag="3"/>
                    <ComboBoxItem Content="Table 4" Tag="4"/>
                    <ComboBoxItem Content="Table 5" Tag="5"/>
                </ComboBox>
                <Button Content="↻  Refresh" Click="Refresh_Click"
                        Background="{DynamicResource PrimaryBrush}" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="20,0,0,0"/>
                <Button Content="📤  Export Excel" Click="Export_Click"
                        Background="{DynamicResource SuccessBrush}" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="10,0,0,0"/>
                <Button Content="📄  GST Report" Click="ExportGst_Click"
                        Background="#E67E22" Foreground="White"
                        BorderThickness="0" Padding="16,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="10,0,0,0"/>
                <TextBlock x:Name="RowCountText" FontSize="13" Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Journal DataGrid -->
        <Border Grid.Row="2" Margin="24" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="JournalGrid"
                          Style="{StaticResource PremiumGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{DynamicResource TextPrimary}"
                          RowDetailsVisibilityMode="VisibleWhenSelected">

                    <!-- Row details (expandable items) -->
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource AppBackground}" Padding="20,12" Margin="0,0,0,4" MaxHeight="300">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                    <TextBlock Text="ORDER ITEMS" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat=×{0}}" Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat=Rs.{0:N2}}" Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding TaxPercentage, StringFormat={}{0}%}" Foreground="#E67E22" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Total, StringFormat=Rs.{0:N2}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" TextAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="80"/>
                        <DataGridTextColumn Header="DATE &amp; TIME" Binding="{Binding CreatedAt, StringFormat={}{0:dd MMM yyyy  hh:mm tt}}" Width="190">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding"       Value="14,0"/>
                                    <Setter Property="FontWeight"    Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TABLE" Binding="{Binding TableNumber, StringFormat=Table {0}}" Width="100"/>
                        <DataGridTextColumn Header="ITEMS" Binding="{Binding ItemCount}" Width="70"/>
                        <DataGridTemplateColumn Header="AMOUNT" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat=Rs.{0:N2}}" 
                                               FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                               Padding="14,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ACTIONS" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                        <Button Content="🖨 Reprint" Click="PrintReceipt_Click" Tag="{Binding Id}" Style="{StaticResource TouchButton}"
                                                Padding="10,2" FontSize="11" Margin="0,0,6,0" Background="{DynamicResource SecondaryBrush}"/>
                                        <Button Content="✏ Edit" Click="EditOrder_Click" Tag="{Binding}" Style="{StaticResource TouchButton}"
                                                Padding="10,2" FontSize="11" Background="{DynamicResource PrimaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <ctrl:PaginationControl x:Name="JournalPager" Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
