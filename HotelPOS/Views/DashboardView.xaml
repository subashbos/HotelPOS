<UserControl x:Class="HotelPOS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ctrl="clr-namespace:HotelPOS.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="1400" d:DesignWidth="1200"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>
        <Style x:Key="DateBoxStyle" TargetType="DatePicker">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Summary Header -->
            <RowDefinition Height="*"/>    <!-- Main Content Area -->
        </Grid.RowDefinitions>

        <!-- Top Summary Bar (Fixed) -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title & Filters -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Executive Dashboard" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Real-time business performance analytics" FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12,4" Margin="0,0,12,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                                <DatePicker x:Name="CustomFrom" Style="{StaticResource DateBoxStyle}" SelectedDateChanged="CustomDate_Changed" Margin="0,0,12,0" BorderThickness="0" Background="Transparent" Width="110"/>
                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                                <DatePicker x:Name="CustomTo" Style="{StaticResource DateBoxStyle}" SelectedDateChanged="CustomDate_Changed" BorderThickness="0" Background="Transparent" Width="110"/>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <RadioButton x:Name="TodayFilter" Content="Today" IsChecked="True" Style="{StaticResource FilterPill}" Click="Filter_Checked" Margin="0,0,8,0"/>
                            <RadioButton x:Name="WeekFilter" Content="Weekly" Style="{StaticResource FilterPill}" Click="Filter_Checked" Margin="0,0,8,0"/>
                            <RadioButton x:Name="AllFilter" Content="All Time" Style="{StaticResource FilterPill}" Click="Filter_Checked"/>
                        </StackPanel>

                        <Button Click="Refresh_Click" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand" Width="42" Height="42">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="↻" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                        </Button>
                        
                        <Button Click="Export_Click" Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" Cursor="Hand" Width="42" Height="42" Margin="12,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="📥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- KPI Cards Row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Revenue Card -->
                    <Border Grid.Column="0" BorderThickness="0" CornerRadius="15" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00B4DB" Offset="0"/>
                                <GradientStop Color="#0083B0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Color="#0083B0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="TOTAL REVENUE" FontSize="11" FontWeight="ExtraBold" Foreground="White" Opacity="0.8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="RevenueValueText" Text="Rs. 0.00" FontSize="26" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="22" Background="#25FFFFFF" VerticalAlignment="Center">
                                <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Orders Card -->
                    <Border Grid.Column="2" BorderThickness="0" CornerRadius="15" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7028E4" Offset="0"/>
                                <GradientStop Color="#E5B2CA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Color="#7028E4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ORDERS PLACED" FontSize="11" FontWeight="ExtraBold" Foreground="White" Opacity="0.8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="OrdersValueText" Text="0" FontSize="26" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="22" Background="#25FFFFFF" VerticalAlignment="Center">
                                <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Avg Ticket Card -->
                    <Border Grid.Column="4" BorderThickness="0" CornerRadius="15" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#11998E" Offset="0"/>
                                <GradientStop Color="#38EF7D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Color="#11998E"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AVG. TICKET" FontSize="11" FontWeight="ExtraBold" Foreground="White" Opacity="0.8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="AvgValueText" Text="Rs. 0.00" FontSize="26" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="22" Background="#25FFFFFF" VerticalAlignment="Center">
                                <TextBlock Text="📈" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Top Item Card -->
                    <Border Grid.Column="6" BorderThickness="0" CornerRadius="15" Padding="24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EB3349" Offset="0"/>
                                <GradientStop Color="#F45C43" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Color="#EB3349"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="TOP ITEM" FontSize="11" FontWeight="ExtraBold" Foreground="White" Opacity="0.8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TopItemText" Text="—" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="22" Background="#25FFFFFF" VerticalAlignment="Center">
                                <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="32,24">
                <StackPanel>
                    <!-- ── Row 1: Charts ── -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Revenue Performance -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Revenue Performance" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
                                <ItemsControl x:Name="SalesChart" Height="220" Background="Transparent">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Canvas.Left="{Binding X}" Canvas.Bottom="25">
                                                <Border Width="38" Height="{Binding BarHeight}" 
                                                        CornerRadius="8,8,4,4" 
                                                        ToolTip="{Binding ToolTipText}"
                                                        VerticalAlignment="Bottom">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                            <GradientStop Color="#00C6FB" Offset="0"/>
                                                            <GradientStop Color="#005BEA" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.9"/>
                                                                    <Setter Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#00C6FB" Opacity="0.5"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock Text="{Binding MonthName}" FontSize="10" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" Margin="0,0,0,-22"
                                                           VerticalAlignment="Bottom"
                                                           Foreground="{DynamicResource TextMuted}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        
                        <!-- Sales Mix -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Sales Mix (By Category)" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
                                <Grid Height="220">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Pie Chart Area -->
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ItemsControl x:Name="PieItemsControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Grid Width="180" Height="180"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Path Data="{Binding PathData}" Fill="{Binding FillColor}" ToolTip="{Binding ToolTipText}">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="0.8"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black" Opacity="0.2"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Inner Circle for Donut effect -->
                                        <Ellipse Width="110" Height="110" Fill="{DynamicResource SurfaceBrush}"/>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="TOTAL" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="PieTotalText" Text="100%" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Legend -->
                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20,0,0,0" Width="140">
                                        <ItemsControl x:Name="SalesMixLegend">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="12" Height="12" CornerRadius="6" Background="{Binding FillColor}" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding CategoryName}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Percentage, StringFormat={}{0:N1}%}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Row 2: Tables ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Transactions -->
                        <StackPanel>
                            <!-- Recent Orders -->
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24" Margin="0,0,0,24">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Recent Orders" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    </Grid>
                                    <DataGrid x:Name="RecentGrid" Height="240" Style="{StaticResource PremiumGrid}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="50" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                            <DataGridTextColumn Header="TIME" Binding="{Binding CreatedAt, StringFormat=hh:mm tt}" Width="80" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                            <DataGridTextColumn Header="TABLE" Binding="{Binding TableNumber, StringFormat=Table {0}}" Width="90"/>
                                            <DataGridTemplateColumn Header="TOTAL" Width="*" HeaderStyle="{StaticResource RightHeader}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Total, StringFormat=Rs. {0:N2}}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,14,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="ACTIONS" Width="100" HeaderStyle="{StaticResource CenterHeader}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Button Style="{StaticResource ActionBtn}" Content="✎" ToolTip="Edit" Click="EditOrder_Click" Tag="{Binding}"/>
                                                            <Button Style="{StaticResource ActionBtn}" Content="🖨" ToolTip="Print Preview" Margin="6,0,0,0" Foreground="{DynamicResource AccentBrush}" Click="PrintOrder_Click" Tag="{Binding}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <ctrl:PaginationControl x:Name="RecentPager" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Date-wise -->
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Date-wise Summary" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    </Grid>
                                    <DataGrid x:Name="DateGrid" Height="300" Style="{StaticResource PremiumGrid}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                            <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd MMM yyyy}" Width="140"/>
                                            <DataGridTextColumn Header="ORDERS" Binding="{Binding OrderCount}" Width="80" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                            <DataGridTextColumn Header="GROSS" Binding="{Binding GrossRevenue, StringFormat=Rs. {0:N2}}" Width="*" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                            <DataGridTextColumn Header="GST" Binding="{Binding GstAmount, StringFormat=Rs. {0:N2}}" Width="120" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                            <DataGridTemplateColumn Header="NET" Width="130" HeaderStyle="{StaticResource RightHeader}">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding NetIncome, StringFormat=Rs. {0:N2}}" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <ctrl:PaginationControl x:Name="DatePager" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Column: Table Stats -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Revenue by Table" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                </Grid>
                                <DataGrid x:Name="TableGrid" Height="580" Style="{StaticResource PremiumGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                        <DataGridTextColumn Header="TABLE" Binding="{Binding TableNumber, StringFormat=Table {0}}" Width="90"/>
                                        <DataGridTextColumn Header="ORDERS" Binding="{Binding OrderCount}" Width="70" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                        <DataGridTemplateColumn Header="REVENUE" Width="*" HeaderStyle="{StaticResource RightHeader}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TotalRevenue, StringFormat=Rs. {0:N0}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <ctrl:PaginationControl x:Name="TablePager" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Row 3: Items & Payments ── -->
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>

                        <!-- Top Items -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Top Selling Items" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                </Grid>
                                <DataGrid x:Name="ItemGrid" Height="400" Style="{StaticResource PremiumGrid}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="50" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                        <DataGridTextColumn Header="ITEM NAME" Binding="{Binding ItemName}" Width="*"/>
                                        <DataGridTextColumn Header="PRICE" Binding="{Binding UnitPrice, StringFormat=Rs. {0:N2}}" Width="100" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                        <DataGridTextColumn Header="QTY" Binding="{Binding TotalQtySold}" Width="70" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                        <DataGridTemplateColumn Header="REVENUE" Width="120" HeaderStyle="{StaticResource RightHeader}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TotalRevenue, StringFormat=Rs. {0:N2}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <ctrl:PaginationControl x:Name="ItemPager" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Payment Mode -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Payment Summary" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                                <DataGrid x:Name="PaymentModeGrid" Style="{StaticResource PremiumGrid}" RowHeight="50">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="50" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                        <DataGridTemplateColumn Header="MODE" Width="*" HeaderStyle="{StaticResource CenterHeader}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource AppBackground}" CornerRadius="8" Padding="10,4" HorizontalAlignment="Center" Margin="4,0">
                                                        <TextBlock Text="{Binding PaymentMode}" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="COUNT" Binding="{Binding OrderCount}" Width="80" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                        <DataGridTemplateColumn Header="REVENUE" Width="110" HeaderStyle="{StaticResource RightHeader}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Revenue, StringFormat=Rs. {0:N0}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
