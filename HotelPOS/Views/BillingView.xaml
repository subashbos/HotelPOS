<UserControl x:Class="HotelPOS.Views.BillingView" x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HotelPOS"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1280"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="NavPillStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18" Padding="{TemplateBinding Padding}"
                                MinWidth="36" MinHeight="36">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SecondaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <local:IdToEnabledConverter x:Key="IdToEnabledConverter"/>
        <local:StockToColorConverter x:Key="StockToColorConverter"/>
        <local:StockToOpacityConverter x:Key="StockToOpacityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header banner -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>     <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ══ COMPACT HEADER BANNER ══ -->
        <Border Background="{DynamicResource HeaderBrush}" Padding="15,10" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🧾  POS Billing" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="F1: Search • F4: Checkout • Esc: Close" FontSize="11" Foreground="#BDD5E7" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource SecondaryBrush}" Padding="12,6" CornerRadius="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage, StringFormat='Status: {0}'}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Row="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT COLUMN ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Active Billing Tabs (Moved inside left column) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12"
                            Visibility="{Binding IsTableVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding ActiveTabs}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" 
                                        Command="{Binding DataContext.SelectTableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource NavPillStyle}"
                                        Padding="10,0" Margin="0,0,10,0"
                                        Width="36" Height="36">
                                    <Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource IdToEnabledConverter}">
                                            <Binding Path="."/>
                                            <Binding Path="DataContext.TableNumber" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </Button.IsEnabled>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button x:Name="AddTableButton" Content="+ New Bill" 
                            Command="{Binding OpenTableLayoutCommand}"
                            Style="{StaticResource NavPillStyle}"
                            Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"
                            Width="100" Height="36"/>

                    <Popup IsOpen="{Binding IsTableLayoutOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=AddTableButton}" Placement="Bottom" HorizontalOffset="-200" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="15" Width="320">
                            <Border.Effect><DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.2"/></Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Select Table" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimary}"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" Margin="0,0,5,0"/><TextBlock Text="Empty" FontSize="11" Margin="0,0,15,0" Foreground="{DynamicResource TextMuted}"/>
                                    <Ellipse Width="10" Height="10" Fill="{DynamicResource DangerBrush}" Margin="0,0,5,0"/><TextBlock Text="Occupied" FontSize="11" Margin="0,0,15,0" Foreground="{DynamicResource TextMuted}"/>
                                    <Ellipse Width="10" Height="10" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,5,0"/><TextBlock Text="Current" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                                
                                <ItemsControl ItemsSource="{Binding Tables}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectTableCommand, ElementName=Root}"
                                                    CommandParameter="{Binding TableNumber}"
                                                    Margin="4" Height="50" Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding TableName}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Button Content="Close" Command="{Binding OpenTableLayoutCommand}" CommandParameter="False"
                                        Margin="0,15,0,0" HorizontalAlignment="Right" Style="{StaticResource NavPillStyle}" Background="Transparent"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- Menu Panel -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Menu Items" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Type to search or browse by category" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,10,0,0" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                        <UniformGrid Columns="3">
                            <Button x:Name="BtnDineIn" Content="🍽 Dine In" Tag="DineIn" Click="OrderTypeBtn_Click" Padding="0,9" FontSize="12" FontWeight="SemiBold" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}" Cursor="Hand"/>
                            <Button x:Name="BtnTakeaway" Content="🥡 Takeaway" Tag="Takeaway" Click="OrderTypeBtn_Click" Padding="0,9" FontSize="12" FontWeight="SemiBold" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}" Cursor="Hand"/>
                            <Button x:Name="BtnOnline" Content="🌐 Online" Tag="Online" Click="OrderTypeBtn_Click" Padding="0,9" FontSize="12" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                        </UniformGrid>
                    </Border>

                    <Border Grid.Row="2" Margin="0,8,0,0" Padding="0,0,0,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" Command="{Binding DataContext.FilterByCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" Style="{StaticResource NavPillStyle}">
                                            <Button.IsEnabled>
                                                <MultiBinding Converter="{StaticResource IdToEnabledConverter}">
                                                    <Binding Path="Id"/>
                                                    <Binding Path="DataContext.SelectedCategoryId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </Button.IsEnabled>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" CornerRadius="8">
                            <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" TextChanged="SearchBox_TextChanged" Padding="12,10" FontSize="15" BorderThickness="0" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimary}" PreviewKeyDown="SearchBox_PreviewKeyDown" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                        </Border>
                        <Button Grid.Column="1" Content="➕  Add" Margin="10,0,0,0" Click="AddItem_Click" Background="{DynamicResource PrimaryBrush}" Foreground="White" Padding="16,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>

                        <Popup x:Name="AutoPopup" PlacementTarget="{Binding ElementName=SearchBox}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" CornerRadius="0,0,10,10" MinWidth="320">
                                <Border.Effect><DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.2"/></Border.Effect>
                                <ListBox x:Name="AutoList" ItemsSource="{Binding Items}" SelectedValuePath="Id" MaxHeight="350" BorderThickness="0" FontSize="14" Background="Transparent" Foreground="{DynamicResource TextPrimary}" ScrollViewer.VerticalScrollBarVisibility="Auto" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" PreviewMouseLeftButtonDown="AutoList_MouseDown" KeyDown="AutoList_KeyDown">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}" Padding="14,10"><ContentPresenter /></Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Border Padding="12,4" Background="{DynamicResource SecondaryBrush}" CornerRadius="16" Margin="8,0,0,0"><TextBlock Text="{Binding Price, StringFormat=Rs. {0:N2}}" Foreground="White" FontWeight="Bold" FontSize="13"/></Border>
                                                    <TextBlock Text="{Binding TaxPercentage, StringFormat={}({0}% GST)}" Foreground="#E67E22" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    <Border Padding="8,2" Background="{Binding StockQuantity, Converter={StaticResource StockToColorConverter}}" CornerRadius="10" Margin="8,0,0,0" 
                                                            Visibility="{Binding TrackInventory, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding StockQuantity, StringFormat='Stock: {0}'}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>

                    <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ItemCardList" ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="16,12" Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Cursor="Hand" MouseLeftButtonDown="ItemCard_Click"
                                            Opacity="{Binding StockQuantity, Converter={StaticResource StockToOpacityConverter}}">
                                        <Border.Style><Style TargetType="Border"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/></Trigger></Style.Triggers></Style></Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Category.Name}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Text=" • OUT OF STOCK" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" Margin="8,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding TrackInventory}" Value="True"/>
                                                                            <Condition Binding="{Binding StockQuantity}" Value="0"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="14,8" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Margin="8,0"><StackPanel><TextBlock Text="{Binding Price, StringFormat=Rs. {0:N2}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/><TextBlock Text="{Binding TaxPercentage, StringFormat=GST {0}%}" FontSize="10" Foreground="#E67E22"/></StackPanel></Border>
                                            <Button Grid.Column="2" Content="＋" Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="38" Height="38" Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontSize="18" FontWeight="Bold">
                                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                                                <Button.IsEnabled>
                                                    <MultiBinding Converter="{StaticResource IdToEnabledConverter}" ConverterParameter="StockCheck">
                                                        <Binding Path="StockQuantity"/>
                                                        <Binding Path="TrackInventory"/>
                                                    </MultiBinding>
                                                </Button.IsEnabled>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── RIGHT: Cart Panel ── -->
        <Border Grid.Column="2" VerticalAlignment="Stretch" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto" MaxHeight="300"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Current Bill" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <Button Content="Move Items" Command="{Binding ToggleTransferModeCommand}" HorizontalAlignment="Right" Style="{StaticResource NavPillStyle}" Visibility="{Binding IsTableVisible, Converter={StaticResource BoolToVisibilityConverter}}" Background="{DynamicResource SecondaryBrush}" Foreground="White" BorderThickness="0" Padding="10,4"/>
                    </Grid>

                    <DataGrid x:Name="CartGrid" Grid.Row="1" ItemsSource="{Binding Cart}" SelectedItem="{Binding SelectedCartRow}" 
                              Style="{StaticResource PremiumGrid}" RowHeight="34"
                              CellEditEnding="CartGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding SNo}" Width="35" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                            <DataGridTextColumn Header="ITEM" Binding="{Binding ItemName}" Width="2.5*" IsReadOnly="True" HeaderStyle="{StaticResource BaseColumnHeader}"/>
                            <DataGridTemplateColumn Header="QTY" Width="60" HeaderStyle="{StaticResource CenterHeader}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><TextBox Text="{Binding Quantity, UpdateSourceTrigger=LostFocus}" LostFocus="GridTextBox_LostFocus" PreviewKeyDown="QtyTextBox_PreviewKeyDown" PreviewTextInput="NumberOnly_PreviewTextInput" DataObject.Pasting="DataObject_OnPasting" GotFocus="GridTextBox_GotFocus" HorizontalContentAlignment="Center" BorderThickness="1" Padding="2"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="TAX %" Binding="{Binding TaxPercentage, StringFormat={}{0:0.#}%}" Width="65" IsReadOnly="True" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                            <DataGridTemplateColumn Header="PRICE" Width="95" HeaderStyle="{StaticResource RightHeader}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><TextBox Text="{Binding Price, UpdateSourceTrigger=LostFocus, StringFormat={}{0:N2}}" LostFocus="GridTextBox_LostFocus" PreviewKeyDown="PriceTextBox_PreviewKeyDown" PreviewTextInput="DecimalOnly_PreviewTextInput" DataObject.Pasting="Decimal_OnPasting" GotFocus="GridTextBox_GotFocus" HorizontalContentAlignment="Right" BorderThickness="1" Padding="2,2,8,2"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="TOTAL" Width="110" IsReadOnly="True" HeaderStyle="{StaticResource RightHeader}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Total, StringFormat=Rs.{0:N2}}" FontWeight="Bold" Style="{StaticResource RightCell}"/></DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2">
                        <UniformGrid Columns="4" Margin="0,4,0,0">
                            <Button Content="＋" Command="{Binding AddToCartCommand}" CommandParameter="{Binding SelectedCartRow}" Padding="2" FontSize="14" Margin="0,0,2,0"/>
                            <Button Content="－" Command="{Binding DecreaseQuantityCommand}" CommandParameter="{Binding SelectedCartRow}" Background="{DynamicResource SecondaryBrush}" Foreground="White" Padding="2" FontSize="14" Margin="0,0,2,0"/>
                            <Button Content="🗑 Rem" Command="{Binding RemoveFromCartCommand}" CommandParameter="{Binding SelectedCartRow}" Background="{DynamicResource DangerBrush}" Foreground="White" Padding="2" FontSize="10" Margin="0,0,2,0"/>
                            <Button Content="✖ Clr" Command="{Binding ClearCartCommand}" Background="#E74C3C" Foreground="White" Padding="2" FontSize="10"/>
                        </UniformGrid>
                        
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button Content="🍽 Kitchen" Command="{Binding HoldOrderCommand}" Background="#F39C12" Foreground="White" Padding="2" FontSize="11" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="{Binding HeldOrders.Count, StringFormat='Held ({0})'}" Command="{Binding ToggleHeldOrdersCommand}" Background="{DynamicResource SecondaryBrush}" Foreground="White" Padding="2" FontSize="11"/>
                        </Grid>

                        <Popup IsOpen="{Binding IsHeldOrdersPopupOpen}" StaysOpen="False" Placement="Top" HorizontalOffset="-100">
                            <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Width="300" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Held Orders" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding HeldOrders}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.ResumeOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#EEE" Padding="8" HorizontalContentAlignment="Stretch">
                                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding HoldName}" FontWeight="SemiBold"/><TextBlock Text="{Binding HeldAt, StringFormat=hh:mm tt}" FontSize="10" Foreground="{DynamicResource TextMuted}"/></StackPanel><TextBlock Grid.Column="1" Text="Resume" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/></Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Border Margin="0,4,0,0" Padding="8,6" CornerRadius="8" Background="{DynamicResource AppBackground}">
                            <StackPanel>
                                <Expander Header="Customer Details" IsExpanded="False" FontSize="10" Margin="0,0,0,6">
                                    <Grid Margin="0,4,0,4">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Name:" FontSize="10" Margin="0,0,8,4"/><TextBox Grid.Column="1" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" Padding="4,2"/>
                                        <TextBlock Grid.Row="1" Text="Phone:" FontSize="10" Margin="0,0,8,4"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" Padding="4,2" PreviewTextInput="NumberOnly_PreviewTextInput"/>
                                        <TextBlock Grid.Row="2" Text="GSTIN:" FontSize="10" Margin="0,0,8,0"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CustomerGstin, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" CharacterCasing="Upper"/>
                                    </Grid>
                                </Expander>

                                <!-- PAY + DISC row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="PAY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="PaymentModeCombo" SelectedValue="{Binding PaymentMode}" SelectedValuePath="Content" Width="100" Height="32" VerticalContentAlignment="Center" DropDownClosed="PaymentModeCombo_DropDownClosed">
                                            <ComboBoxItem Content="Cash"/>
                                            <ComboBoxItem Content="Card"/>
                                            <ComboBoxItem Content="UPI"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="DISC" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="DiscountBox" Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}" Width="80" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PreviewKeyDown="DiscountBox_PreviewKeyDown" PreviewTextInput="DecimalOnly_PreviewTextInput" DataObject.Pasting="Decimal_OnPasting"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Bill Breakdown -->
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,4,0,4" Margin="0,0,0,4">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,3" Visibility="Collapsed">
                                            <TextBlock Text="Subtotal" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                            <TextBlock HorizontalAlignment="Right" Text="{Binding Subtotal, StringFormat=Rs. {0:N2}}" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3" Visibility="Collapsed">
                                            <TextBlock Text="GST" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                            <TextBlock HorizontalAlignment="Right" Text="{Binding GstAmount, StringFormat=Rs. {0:N2}}" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,5" Visibility="Collapsed">
                                            <TextBlock Text="Discount" FontSize="12" Foreground="#E67E22"/>
                                            <TextBlock HorizontalAlignment="Right" Text="{Binding DiscountAmount, StringFormat=- Rs. {0:N2}}" FontSize="12" Foreground="#E67E22"/>
                                        </Grid>
                                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,5,0,0">
                                            <Grid>
                                                <TextBlock Text="TOTAL" FontSize="14" FontWeight="Bold"/>
                                                <TextBlock HorizontalAlignment="Right" Text="{Binding TotalAmount, StringFormat=Rs. {0:N2}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="CheckoutButton" Command="{Binding SaveOrderCommand}" Padding="10,12" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,8,0,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#10AC84"/> <!-- Premium Teal/Green -->
                                            <Setter Property="Content" Value="💳  CHECKOUT (F4)"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <ControlTemplate.Resources>
                                                            <Storyboard x:Key="CheckoutPulse" RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="Opacity" From="1.0" To="0.8" Duration="0:0:0.8" AutoReverse="True"/>
                                                                <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" From="12" To="28" Duration="0:0:0.8" AutoReverse="True"/>
                                                            </Storyboard>
                                                        </ControlTemplate.Resources>
                                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <ContentPresenter.Effect>
                                                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3"/>
                                                                </ContentPresenter.Effect>
                                                            </ContentPresenter>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#1DD1A1"/>
                                                                <Setter TargetName="bd" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                            <Trigger Property="IsFocused" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                                <Setter TargetName="bd" Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.8" Color="{DynamicResource SuccessColor}"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard x:Name="CheckoutPulse_Begin" Storyboard="{StaticResource CheckoutPulse}"/>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="CheckoutPulse_Begin"/>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Content" Value="💾  UPDATE BILL (F4)"/>
                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="CancelEditButton" Content="✖ Cancel Update" Command="{Binding CancelEditCommand}" Margin="0,4,0,0" Padding="8" Background="{DynamicResource DangerBrush}" Foreground="White" FontWeight="Bold">
                                    <Button.Style><Style TargetType="Button"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsEditMode}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
