<UserControl x:Class="HotelPOS.Views.SalesReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ctrl="clr-namespace:HotelPOS.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>
        <Style x:Key="DateBoxStyle" TargetType="DatePicker">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Filters Header -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Top Filter Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel>
                    <TextBlock Text="Detailed Sales Report" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Analyze your transaction history with granular filters" FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Filters Grid -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Date -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>    <!-- Search -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/> <!-- Payment Mode -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/> <!-- Category -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/> <!-- Order Type -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/> <!-- Actions -->
                    </Grid.ColumnDefinitions>

                    <!-- Date Range -->
                    <Border Grid.Column="0" Background="{DynamicResource AppBackground}" CornerRadius="12" Padding="12,4">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Range:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                            <DatePicker x:Name="FilterFrom" Style="{StaticResource DateBoxStyle}" SelectedDateChanged="Filter_Changed" Width="110"/>
                            <TextBlock Text="to" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                            <DatePicker x:Name="FilterTo" Style="{StaticResource DateBoxStyle}" SelectedDateChanged="Filter_Changed" Width="110"/>
                        </StackPanel>
                    </Border>

                    <!-- Search Bar -->
                    <Border Grid.Column="2" Background="{DynamicResource AppBackground}" CornerRadius="12" Padding="12,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.5"/>
                            <TextBox x:Name="SearchText" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                     VerticalContentAlignment="Center" FontSize="13" TextChanged="Filter_Changed"
                                     Tag="Search by Invoice or Customer..."/>
                        </Grid>
                    </Border>

                    <!-- Payment Mode -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Payment Mode" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ComboPayment" Width="120" Height="38" SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Cash"/>
                            <ComboBoxItem Content="Card"/>
                            <ComboBoxItem Content="UPI"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Category" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ComboCategory" Width="150" Height="38" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Filter_Changed"/>
                    </StackPanel>

                    <!-- Order Type (Pills) -->
                    <StackPanel Grid.Column="8" VerticalAlignment="Bottom" Margin="0,0,0,2">
                        <TextBlock Text="Order Type" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="TypeAll" Content="All" IsChecked="True" Style="{StaticResource FilterPill}" Click="Filter_Changed" Margin="0,0,8,0"/>
                            <RadioButton x:Name="TypeDine" Content="Dine-In" Style="{StaticResource FilterPill}" Click="Filter_Changed" Margin="0,0,8,0"/>
                            <RadioButton x:Name="TypeTake" Content="Takeaway" Style="{StaticResource FilterPill}" Click="Filter_Changed" Margin="0,0,8,0"/>
                            <RadioButton x:Name="TypeOnline" Content="Online" Style="{StaticResource FilterPill}" Click="Filter_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Refresh Button -->
                    <Button Grid.Column="10" Click="Refresh_Click" VerticalAlignment="Bottom" Margin="0,0,0,2"
                            Background="{DynamicResource PrimaryBrush}" Foreground="White" Width="42" Height="42">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="↻" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content (Grid) -->
        <Border Grid.Row="1" Padding="32,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="SalesGrid" Style="{StaticResource PremiumGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                        <DataGridTextColumn Header="DATE &amp; TIME" Binding="{Binding CreatedAt, StringFormat=dd MMM yyyy hh:mm tt}" Width="180"/>
                        <DataGridTextColumn Header="INVOICE" Binding="{Binding InvoiceNumber}" Width="140"/>
                        <DataGridTextColumn Header="CUSTOMER" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTemplateColumn Header="TYPE" Width="100" HeaderStyle="{StaticResource CenterHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#F0F4F8" CornerRadius="6" Padding="8,2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding OrderType}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMuted}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="PAYMENT" Width="100" HeaderStyle="{StaticResource CenterHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PaymentMode}" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="AMOUNT" Width="130" HeaderStyle="{StaticResource RightHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Total, StringFormat=Rs. {0:N2}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ACTIONS" Width="100" HeaderStyle="{StaticResource CenterHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource ActionBtn}" Content="✎" ToolTip="Edit Order" Click="EditOrder_Click" Tag="{Binding}"/>
                                        <Button Style="{StaticResource ActionBtn}" Content="🖨" ToolTip="Print Receipt" Margin="6,0,0,0" Foreground="{DynamicResource AccentBrush}" Click="PrintOrder_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination & Summary Footer -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20,12" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Total Orders:" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="TotalOrdersCount" Text="0" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="8,0,24,0"/>
                            
                            <TextBlock Text="Total Revenue:" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                            <TextBlock x:Name="TotalRevenueSum" Text="Rs. 0.00" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <ctrl:PaginationControl x:Name="Pager" Grid.Column="1" HorizontalAlignment="Center"/>

                        <Button Grid.Column="2" Click="Export_Click" Style="{StaticResource ActionBtn}" Foreground="{DynamicResource PrimaryBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📥" Margin="0,0,8,0"/>
                                <TextBlock Text="Export to Excel" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
