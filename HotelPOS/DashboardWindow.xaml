<Window x:Class="HotelPOS.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HotelPOS.Views"
        xmlns:ctrl="clr-namespace:HotelPOS.Controls"
        Title="Hotel POS - Managed Workspace"
        Height="840" Width="1260" MinHeight="660" MinWidth="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded" Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        Icon="/Resources/app_icon.png">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!--
            NavBtn: Content = emoji icon, Tag = full label text.
            Layout switches automatically via DataTrigger on SidebarBorder.Tag.
        -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#7A8C9E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="64"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Active left-border indicator -->
                            <Rectangle x:Name="ActiveBar" Width="3" HorizontalAlignment="Left"
                                       Fill="{DynamicResource PrimaryBrush}" Visibility="Collapsed"/>
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <Grid>
                                    <!-- COMPACT layout: icon + small label stacked -->
                                    <StackPanel x:Name="CompactLayout"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   FontSize="20" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{TemplateBinding Tag}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                                   Foreground="{TemplateBinding Foreground}"/>
                                    </StackPanel>

                                    <!-- EXPANDED layout: icon + text side-by-side -->
                                    <StackPanel x:Name="ExpandedLayout" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="18,0" Visibility="Collapsed">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   FontSize="20" VerticalAlignment="Center" Width="28"/>
                                        <TextBlock Text="{TemplateBinding Tag}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Foreground="{TemplateBinding Foreground}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E2A38"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#0D2137"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Switch to expanded layout -->
                            <DataTrigger Binding="{Binding Tag, ElementName=SidebarBorder}" Value="expanded">
                                <Setter TargetName="CompactLayout"  Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ExpandedLayout" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Height shrinks slightly in expanded mode (horizontal layout is shorter) -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, ElementName=SidebarBorder}" Value="expanded">
                    <Setter Property="Height" Value="48"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══ -->
        <Border x:Name="SidebarBorder" Background="#151D27" Grid.Column="0" Tag="compact">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header: logo + toggle -->
                    <RowDefinition Height="*"/>     <!-- Nav -->
                    <RowDefinition Height="Auto"/>  <!-- Bottom -->
                </Grid.RowDefinitions>

                <!-- ─── Header: App icon + expandable title ─── -->
                <Border BorderBrush="#232F3E" BorderThickness="0,0,0,1" Padding="0,14,0,14">
                    <StackPanel>
                        <!-- Toggle button -->
                        <Button Click="ToggleSidebar_Click" Background="Transparent"
                                BorderThickness="0" Cursor="Hand" ToolTip="Toggle Sidebar"
                                HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock x:Name="ToggleIcon" Text="≡"
                                       FontSize="22" FontWeight="Bold" Foreground="#7A8C9E"/>
                        </Button>

                        <!-- Logo row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Source="/Resources/app_icon.png" Width="32" Height="32"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock x:Name="SidebarLogoText" Text="Hotel POS"
                                       FontSize="16" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Navigation ─── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Margin="0,6,0,6">
                    <StackPanel>

                        <!-- OPERATIONS -->
                        <StackPanel x:Name="ModuleOps">
                            <Button x:Name="NavBilling"  Content="🖥" Tag="Billing POS"
                                    ToolTip="Billing POS" Style="{StaticResource NavBtn}" Click="NavBilling_Click"/>
                            <Button x:Name="NavShift"    Content="💵" Tag="Shift"
                                    ToolTip="Shift"       Style="{StaticResource NavBtn}" Click="NavShift_Click"/>
                        </StackPanel>

                        <!-- INVENTORY -->
                        <StackPanel x:Name="ModuleInv">
                            <Button x:Name="NavMenu"   Content="📋" Tag="Items"
                                    ToolTip="Items"      Style="{StaticResource NavBtn}" Click="NavMenu_Click"/>
                            <Button x:Name="NavCats"   Content="🏷" Tag="Categories"
                                    ToolTip="Categories" Style="{StaticResource NavBtn}" Click="NavCats_Click"/>
                            <Button x:Name="NavTables" Content="🪑" Tag="Tables"
                                    ToolTip="Tables"     Style="{StaticResource NavBtn}" Click="NavTables_Click"/>
                        </StackPanel>

                        <!-- ANALYTICS -->
                        <StackPanel x:Name="ModuleStats">
                            <Button x:Name="NavDash"       Content="📊" Tag="Analytics"
                                    ToolTip="Dashboard"    Style="{StaticResource NavBtn}" Click="NavDash_Click" IsEnabled="False"/>
                            <Button x:Name="NavSales"      Content="📈" Tag="Sales Report"
                                    ToolTip="Sales Report" Style="{StaticResource NavBtn}" Click="NavSales_Click"/>
                            <Button x:Name="NavItemReport" Content="🍽" Tag="Item Report"
                                    ToolTip="Item Report"  Style="{StaticResource NavBtn}" Click="NavItemReport_Click"/>
                            <Button x:Name="NavLedger"     Content="📒" Tag="Ledger"
                                    ToolTip="Ledger"       Style="{StaticResource NavBtn}" Click="NavLedger_Click"/>
                            <Button x:Name="NavJournal"    Content="📓" Tag="Journal"
                                    ToolTip="Journal"      Style="{StaticResource NavBtn}" Click="NavJournal_Click"/>
                        </StackPanel>

                        <!-- ADMINISTRATION -->
                        <StackPanel x:Name="ModuleAdmin">
                            <Button x:Name="NavSettings" Content="⚙"  Tag="Settings"
                                    ToolTip="Settings"    Style="{StaticResource NavBtn}" Click="NavSettings_Click"/>
                            <Button x:Name="NavRoles"    Content="👥" Tag="Roles"
                                    ToolTip="Roles"       Style="{StaticResource NavBtn}" Click="NavRoles_Click"/>
                            <Button x:Name="NavAudit"    Content="🛡"  Tag="Audit"
                                    ToolTip="Audit"       Style="{StaticResource NavBtn}" Click="NavAudit_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- ─── Bottom: Theme + User + Logout ─── -->
                <Border Grid.Row="2" Background="#0F1820" BorderBrush="#232F3E"
                        BorderThickness="0,1,0,0" Padding="0,12,0,12">
                    <Grid>
                        <!-- COMPACT bottom -->
                        <StackPanel x:Name="BottomCompact" HorizontalAlignment="Center">
                            <Button Click="ThemeToggle_Click" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" ToolTip="Toggle Theme" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="🌓" FontSize="18" Foreground="#6A7D8E"/>
                            </Button>
                            <Border x:Name="UserAvatarBorder" Width="34" Height="34" CornerRadius="17"
                                    Background="{DynamicResource SecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock x:Name="UserAvatarText" Text="A" Foreground="White"
                                           FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button Click="Logout_Click" Cursor="Hand" ToolTip="Logout"
                                    BorderThickness="0" HorizontalAlignment="Center" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="#C62828" CornerRadius="10" Width="40" Height="40">
                                            <Path Fill="White" Stretch="Uniform" Width="16" Height="16"
                                                  Data="M12 2C11.45 2 11 2.45 11 3V13C11 13.55 11.45 14 12 14C12.55 14 13 13.55 13 13V3C13 2.45 12.55 2 12 2ZM7.1 4.1C6.71 3.71 6.08 3.72 5.71 4.12C3.44 6.53 2.53 9.92 3.55 13.26C4.73 17.13 8.31 19.83 12.37 19.99C17.37 20.2 21.56 16.14 21.56 11.16C21.56 8.02 19.96 5.25 17.53 3.64C17.07 3.34 16.46 3.44 16.12 3.88C15.78 4.32 15.87 4.94 16.33 5.24C18.22 6.48 19.44 8.64 19.44 11.09C19.44 14.84 16.53 17.93 12.79 18C8.97 18.07 5.82 14.92 5.82 11.09C5.82 8.64 7.03 6.48 8.91 5.24C9.36 4.95 9.48 4.36 9.14 3.92C8.81 3.48 8.11 3.42 7.1 4.1Z"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#E53935"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock x:Name="UserNameText" Text="Admin" Foreground="#3A4A5A"
                                       FontSize="8" HorizontalAlignment="Center" Margin="0,6,0,0"
                                       TextTrimming="CharacterEllipsis" MaxWidth="74"/>
                        </StackPanel>

                        <!-- EXPANDED bottom -->
                        <Grid x:Name="BottomExpanded" Visibility="Collapsed" Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17"
                                    Background="{DynamicResource SecondaryBrush}" VerticalAlignment="Center">
                                <TextBlock x:Name="UserAvatarTextExp" Text="A" Foreground="White"
                                           FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="UserNameTextExp" Text="Admin"
                                           Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="UserRoleText" Text="Administrator"
                                           Foreground="#4A6070" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Click="ThemeToggle_Click" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Toggle Theme" Margin="0,0,0,6">
                                    <TextBlock Text="🌓" FontSize="16" Foreground="#6A7D8E"/>
                                </Button>
                                <Button Click="Logout_Click" Cursor="Hand" ToolTip="Logout"
                                        BorderThickness="0" Background="Transparent">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd2" Background="#C62828" CornerRadius="8" Padding="8,6">
                                                <TextBlock Text="Logout" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd2" Property="Background" Value="#E53935"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══ MAIN AREA ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="{DynamicResource SurfaceBrush}" Height="56"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Workspace" Foreground="{DynamicResource TextMuted}" FontSize="13"/>
                        <TextBlock Text="  /  " Foreground="{DynamicResource BorderBrush}" FontSize="13"/>
                        <TextBlock x:Name="PageTitleText" Text="Dashboard"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{DynamicResource AppBackground}" CornerRadius="16" Padding="14,7" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox Width="160" Background="Transparent" BorderThickness="0"
                                         VerticalContentAlignment="Center" FontSize="12" Tag="Quick search..."/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="🔔" FontSize="18" Foreground="{DynamicResource TextMuted}"
                                   Margin="0,0,16,0" VerticalAlignment="Center" Cursor="Hand"/>
                        <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource SecondaryBrush}">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl x:Name="MainContentArea" Grid.Row="1" Focusable="False"/>
        </Grid>
    </Grid>
</Window>
