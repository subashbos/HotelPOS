<Window x:Class="HotelPOS.Views.TwoFactorEnrollDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enable Two-Factor Authentication" Height="440" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <StackPanel Margin="28">
        <TextBlock Text="Enable Two-Factor Authentication" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
        <TextBlock Text="Add this account to an authenticator app (Google Authenticator, Microsoft Authenticator, Authy, etc.) using the key below, then enter the 6-digit code it generates to confirm." Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBlock Text="SECRET KEY (MANUAL ENTRY)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="SecretBox" Margin="0,0,0,16" IsReadOnly="True" FontFamily="Consolas" TextWrapping="Wrap"/>

        <TextBlock Text="OR IMPORT VIA URI" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="UriBox" Margin="0,0,0,20" IsReadOnly="True" FontFamily="Consolas" TextWrapping="Wrap" Height="60" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <TextBlock Text="6-DIGIT CODE FROM YOUR APP" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="CodeBox" Margin="0,0,0,20" MaxLength="6"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0"/>
            <Button x:Name="ConfirmButton" Content="Enable" Click="Confirm_Click" Style="{StaticResource PrimaryBtn}" Padding="16,8"/>
        </StackPanel>
    </StackPanel>
</Window>
