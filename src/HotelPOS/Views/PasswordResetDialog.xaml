<Window x:Class="HotelPOS.Views.PasswordResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="#F5F8FC">
    <StackPanel Margin="28">
        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" Foreground="#173F5F" Margin="0,0,0,4"/>
        <TextBlock Text="Enter a new password (min. 10 characters)." FontSize="12" Foreground="#5F6B7A" Margin="0,0,0,20"/>

        <TextBlock Text="NEW PASSWORD" FontSize="11" FontWeight="Bold" Foreground="#5F6B7A" Margin="0,0,0,6"/>
        <PasswordBox x:Name="PwdBox" Padding="12,9" FontSize="14" BorderBrush="#CDD5DF" BorderThickness="1" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Background="#E2E8F0" Foreground="#4A5568" Padding="16,8" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="Reset Password" Click="Ok_Click" Background="#00A896" Foreground="White" Padding="16,8" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
