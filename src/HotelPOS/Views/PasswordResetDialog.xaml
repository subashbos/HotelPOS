<Window x:Class="HotelPOS.Views.PasswordResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <StackPanel Margin="28">
        <TextBlock x:Name="TitleText" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
        <TextBlock Text="Enter a new password (min. 10 characters)." Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>

        <TextBlock Text="NEW PASSWORD" Style="{StaticResource FieldLabel}"/>
        <PasswordBox x:Name="PwdBox" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0"/>
            <Button Content="Reset Password" Click="Ok_Click" Style="{StaticResource PrimaryBtn}" Padding="16,8"/>
        </StackPanel>
    </StackPanel>
</Window>
