<common:EntryDialogWindow x:Class="HotelPOS.Views.ExpenseEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HotelPOS.ViewModels"
        xmlns:common="clr-namespace:HotelPOS.Views.Common"
        mc:Ignorable="d"
        Title="Expense Entry" Height="560" Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary Source="Common/EntryDialogStyles.xaml"/>
    </Window.Resources>

    <Border CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource SurfaceBrush}" Margin="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header Banner -->
            <RowDefinition Height="*"/>     <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/>  <!-- Action Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" CornerRadius="15,15,0,0" Padding="24,14" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CREATE / EDIT EXPENSE" FontSize="10" FontWeight="Bold" Foreground="#14B8A6" Margin="0,0,0,4"/>
                    <TextBlock x:Name="BannerTitle" Text="🧾  Expense Entry" Style="{StaticResource H3TextBlockStyle}" Foreground="White"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Cancel_Click"
                        Background="Transparent" BorderThickness="0" Foreground="White" FontSize="18" FontWeight="Light"
                        Cursor="Hand" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ TWO-COLUMN FORM GRID ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="32"/>  <!-- Spacing gap -->
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Row 0: Title / Date -->
                    <RowDefinition Height="Auto"/>  <!-- Row 1: Category / Amount -->
                    <RowDefinition Height="Auto"/>  <!-- Row 2: Payment Mode / Empty -->
                    <RowDefinition Height="Auto"/>  <!-- Row 3: Full Width Description -->
                </Grid.RowDefinitions>

                <!-- ================= ROW 0: TITLE / DATE ================= -->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="TITLE *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TitleInput" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" GotFocus="Input_GotFocus" Tag="e.g. Vegetable Purchase">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTitleInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding TitleError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsTitleInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="DATE" Style="{StaticResource FieldLabel}"/>
                    <DatePicker SelectedDate="{Binding Date}" Height="34" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- ================= ROW 1: CATEGORY / AMOUNT ================= -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="CATEGORY *" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="AMOUNT (₹) *" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}"
                                 Padding="24,8,12,8" Tag="0.00" Margin="0">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource CurrencyInputField}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAmountInvalid}" Value="True">
                                            <Setter Property="BorderBrush" Value="#EF4444"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBlock Text="₹" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"
                                   Foreground="{DynamicResource TextMuted}" FontSize="13" IsHitTestVisible="False"/>
                    </Grid>
                    <TextBlock Text="{Binding AmountError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsAmountInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- ================= ROW 2: PAYMENT MODE ================= -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="PAYMENT MODE" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding PaymentMode}" SelectedValuePath="Content" Margin="0,0,0,10">
                        <ComboBoxItem Content="Cash"/>
                        <ComboBoxItem Content="Card"/>
                        <ComboBoxItem Content="UPI"/>
                    </ComboBox>
                </StackPanel>

                <!-- ================= ROW 3: FULL WIDTH DESCRIPTION ================= -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                    <TextBlock Text="DESCRIPTION (OPTIONAL)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MultilineInputField}" Height="70" Tag="Add any notes about this expense..."/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ══ ACTION FOOTER ══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,15,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel Button -->
                <Button Content="✕  Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,12,0"/>

                <!-- Save / Update -->
                <Button x:Name="SaveButton" Command="{Binding SaveCommand}"
                        Foreground="White" BorderThickness="0"
                        Padding="24,10" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#10B981"/>
                            <Setter Property="Content" Value="💾  Save Expense"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Content" Value="✏️  Update Expense"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</common:EntryDialogWindow>
