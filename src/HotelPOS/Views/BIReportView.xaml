<UserControl x:Class="HotelPOS.Views.BIReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HotelPOS.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>
        <local:MarginConverter x:Key="MarginConverter"/>
        <Style x:Key="DateBoxStyle" TargetType="DatePicker">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="MetricCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style x:Key="MetricTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header Banner -->
            <RowDefinition Height="Auto"/> <!-- Filter Bar -->
            <RowDefinition Height="*"/>    <!-- Tabs Content -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="32,20">
            <StackPanel>
                <TextBlock Text="📈  Reporting &amp; Business Intelligence" Style="{StaticResource HeroTextBlockStyle}" Foreground="White"/>
                <TextBlock Text="Eliminate blind spots, monitor margins, track wastage, and plan inventory" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="White" Opacity="0.8" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Date Filters -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Global Date Filter -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Analysis Period" Style="{StaticResource FieldLabel}"/>
                        <Border Background="{DynamicResource AppBackground}" CornerRadius="8" Padding="12,0" Height="36" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <DatePicker x:Name="GlobalFrom" Style="{StaticResource DateBoxStyle}" Width="100" SelectedDateChanged="Filter_Changed"/>
                                <TextBlock Text="to" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                <DatePicker x:Name="GlobalTo" Style="{StaticResource DateBoxStyle}" Width="100" SelectedDateChanged="Filter_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Click="Refresh_Click" Style="{StaticResource PrimaryBtn}" Width="36" Height="36" Padding="0" Margin="0,15,0,0" ToolTip="Refresh BI Analytics">
                        <TextBlock Text="↻" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Tab Area -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="16">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}" Margin="12,6"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>

            <!-- 1. OVERVIEW DASHBOARD TAB -->
            <TabItem Header="BI Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- KPIs Grid -->
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="Auto"/> <!-- Chart & Stats -->
                        </Grid.RowDefinitions>

                        <!-- KPI Grid -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MetricCardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Gross Revenue" Style="{StaticResource MetricTitle}"/>
                                    <TextBlock x:Name="TxtTotalRevenue" Text="Rs. 0.00" Style="{StaticResource MetricValue}"/>
                                    <TextBlock Text="Sales before costs" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource MetricCardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Net Profit" Style="{StaticResource MetricTitle}"/>
                                    <TextBlock x:Name="TxtNetProfit" Text="Rs. 0.00" Style="{StaticResource MetricValue}" Foreground="{DynamicResource SuccessBrush}"/>
                                    <TextBlock Text="Revenue minus COGS &amp; Expenses" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource MetricCardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Food Cost %" Style="{StaticResource MetricTitle}"/>
                                    <TextBlock x:Name="TxtFoodCostPct" Text="0.0%" Style="{StaticResource MetricValue}" Foreground="{DynamicResource PrimaryBrush}"/>
                                    <TextBlock Text="Ideal target: 28-35%" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="6" Style="{StaticResource MetricCardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Total Wastage Cost" Style="{StaticResource MetricTitle}"/>
                                    <TextBlock x:Name="TxtWastageCost" Text="Rs. 0.00" Style="{StaticResource MetricValue}" Foreground="{DynamicResource DangerBrush}"/>
                                    <TextBlock Text="Inventory lost or spoiled" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Charts and Summaries -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Monthly Profitability Trends -->
                            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="200"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Monthly Financial &amp; Profit Trends" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Comparison of Gross Revenue, COGS, and Net Income over the last 12 months" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>

                                    <!-- Monthly Bar Chart -->
                                    <ItemsControl x:Name="MonthlyChart" Grid.Row="2" Margin="10,0" ClipToBounds="True">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="600" Height="200" Background="Transparent"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Bottom" Value="0"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="200" Width="36" VerticalAlignment="Bottom">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="4"/>
                                                        <RowDefinition Height="20"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" VerticalAlignment="Bottom">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="2"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Height="{Binding BarHeightRevenue}" Width="14" Background="{DynamicResource ChartRevenueBarBrush}" CornerRadius="4,4,0,0" ToolTip="{Binding ToolTipRevenue}" VerticalAlignment="Bottom"/>
                                                        <Border Grid.Column="2" Height="{Binding BarHeightProfit}" Width="14" Background="{DynamicResource ChartProfitBarBrush}" CornerRadius="4,4,0,0" ToolTip="{Binding ToolTipProfit}" VerticalAlignment="Bottom"/>
                                                    </Grid>
                                                    <TextBlock Grid.Row="2" Text="{Binding MonthName}" FontSize="9" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <!-- Right: Category Cost Distribution -->
                            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Wastage Breakdown" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Inventory loss distribution by reason" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,16"/>

                                    <!-- Dynamic Pie/Legend list -->
                                    <ItemsControl x:Name="WastageReasonsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Color bullet -->
                                                    <Ellipse Width="10" Height="10" Fill="{Binding FillColor}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Reason}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Quantity, StringFormat='{}{0} units'}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding Cost, StringFormat='Rs. {0:N2}'}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- 2. PROFITABILITY & MARGINS TAB -->
            <TabItem Header="Profit Margins">
                <Border Padding="24" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Item Profitability &amp; Cost Control" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Analyze item margins to detect loss-makers and optimize price points" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Click="ExportExcel_Click" Style="{StaticResource ActionBtn}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" Margin="0,0,8,0"/>
                                    <TextBlock Text="Export Margins Report" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <DataGrid x:Name="MarginsGrid" Grid.Row="1" Style="{StaticResource PremiumGrid}" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTextColumn Header="ITEM NAME" Binding="{Binding ItemName}" Width="220" ElementStyle="{StaticResource LeftCell}"/>
                                <DataGridTextColumn Header="CATEGORY" Binding="{Binding CategoryName}" Width="140" ElementStyle="{StaticResource LeftCell}"/>
                                <DataGridTextColumn Header="QTY SOLD" Binding="{Binding QuantitySold}" Width="100" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTextColumn Header="SELL PRICE" Binding="{Binding UnitPrice, StringFormat=Rs. {0:N2}}" Width="120" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                <DataGridTextColumn Header="COST PRICE" Binding="{Binding CostPrice, StringFormat=Rs. {0:N2}}" Width="120" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                <DataGridTextColumn Header="REVENUE" Binding="{Binding TotalRevenue, StringFormat=Rs. {0:N2}}" Width="130" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                <DataGridTextColumn Header="PROFIT" Binding="{Binding Profit, StringFormat=Rs. {0:N2}}" Width="120" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                <DataGridTemplateColumn Header="MARGIN %" Width="110" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MarginPercentage, Converter={StaticResource MarginConverter}}" Value="Low">
                                                                <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBorder}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MarginPercentage, Converter={StaticResource MarginConverter}}" Value="Mid">
                                                                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBorder}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MarginPercentage, Converter={StaticResource MarginConverter}}" Value="High">
                                                                <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBorder}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding MarginPercentage, StringFormat={}{0:N1}%}" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MarginPercentage, Converter={StaticResource MarginConverter}}" Value="Low">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MarginPercentage, Converter={StaticResource MarginConverter}}" Value="Mid">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MarginPercentage, Converter={StaticResource MarginConverter}}" Value="High">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="ACTIONABLE RECOMMENDATION" Binding="{Binding Recommendation}" Width="*" ElementStyle="{StaticResource LeftCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- 3. WASTAGE TRACKING TAB -->
            <TabItem Header="Wastage Tracking">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Log Wastage Form -->
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="Log Inventory Wastage" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Text="Record damaged, expired, or overproduced stocks to update inventory" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>

                                <!-- Item Select -->
                                <TextBlock Text="Select Item *" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="ComboWasteItem" Height="40" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,16"/>

                                <!-- Quantity -->
                                <TextBlock Text="Quantity *" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtWasteQty" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,16" Tag="Enter wasted units qty..."/>

                                <!-- Reason -->
                                <TextBlock Text="Reason for Wastage *" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="ComboWasteReason" Height="40" Margin="0,0,0,16">
                                    <ComboBoxItem Content="Spoilage" IsSelected="True"/>
                                    <ComboBoxItem Content="Overproduction"/>
                                    <ComboBoxItem Content="Damage"/>
                                    <ComboBoxItem Content="Manual Adjustment"/>
                                </ComboBox>

                                <!-- Notes -->
                                <TextBlock Text="Notes / Description" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtWasteNotes" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="8" Margin="0,0,0,24" Tag="Provide brief reason detail..."/>

                                <Button Click="LogWastage_Click" Background="{DynamicResource PrimaryBrush}" Foreground="White" Height="42" Content="Log Wastage Entry" FontWeight="Bold">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Right Column: Recent Wastage DataGrid -->
                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Recent Wastage Log" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>

                            <DataGrid x:Name="WastageGrid" Grid.Row="1" Style="{StaticResource PremiumGrid}" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                    <DataGridTextColumn Header="DATE &amp; TIME" Binding="{Binding WastedAt, StringFormat=dd MMM yyyy hh:mm tt}" Width="160" ElementStyle="{StaticResource LeftCell}"/>
                                    <DataGridTextColumn Header="ITEM NAME" Binding="{Binding ItemName}" Width="*" ElementStyle="{StaticResource LeftCell}"/>
                                    <DataGridTextColumn Header="QTY WASTED" Binding="{Binding Quantity}" Width="110" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                    <DataGridTextColumn Header="REASON" Binding="{Binding Reason}" Width="120" ElementStyle="{StaticResource LeftCell}"/>
                                    <DataGridTextColumn Header="TOTAL COST" Binding="{Binding TotalCost, StringFormat=Rs. {0:N2}}" Width="120" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource RightCell}"/>
                                    <DataGridTextColumn Header="NOTES" Binding="{Binding Notes}" Width="160" ElementStyle="{StaticResource LeftCell}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 4. LOW STOCK & PREDICTIVE ALERTS TAB -->
            <TabItem Header="Low Stock &amp; Alerts">
                <Border Padding="24" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Predictive Inventory Alerts &amp; Reordering" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Real-time warning parameters predicting out-of-stock timelines based on last 30 days demand patterns" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>

                        <DataGrid x:Name="LowStockGrid" Grid.Row="1" Style="{StaticResource PremiumGrid}" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTextColumn Header="ITEM ID" Binding="{Binding ItemId}" Width="80" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTextColumn Header="ITEM NAME" Binding="{Binding ItemName}" Width="*" ElementStyle="{StaticResource LeftCell}"/>
                                <DataGridTextColumn Header="CURRENT STOCK" Binding="{Binding CurrentStock}" Width="130" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTextColumn Header="MIN THRESHOLD" Binding="{Binding MinThreshold}" Width="130" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTextColumn Header="DAILY SALES RATE" Binding="{Binding DailyConsumptionRate, StringFormat='{}{0:0.000} units/day'}" Width="180" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>
                                <DataGridTemplateColumn Header="ALERT STATUS" Width="140" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AlertLevel}" Value="Critical">
                                                                <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBorder}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AlertLevel}" Value="Warning">
                                                                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBorder}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AlertLevel}" Value="Normal">
                                                                <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBorder}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding AlertLevel}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Critical">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Normal">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="EST. DEPLETION TIME" Width="180" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding DaysRemaining, StringFormat='{}{0} days left'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DaysRemaining}" Value="-1">
                                                                <Setter Property="Text" Value="No recent sales (Stable)"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DaysRemaining}" Value="0">
                                                                <Setter Property="Text" Value="Out of Stock"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
