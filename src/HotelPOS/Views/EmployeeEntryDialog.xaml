<common:EntryDialogWindow x:Class="HotelPOS.Views.EmployeeEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:common="clr-namespace:HotelPOS.Views.Common"
        mc:Ignorable="d"
        Title="Employee Entry" Height="700" Width="880"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary Source="Common/EntryDialogStyles.xaml"/>
    </Window.Resources>

    <Border CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource SurfaceBrush}" Margin="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" CornerRadius="15,15,0,0" Padding="24,14" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CREATE / EDIT EMPLOYEE" FontSize="10" FontWeight="Bold" Foreground="#14B8A6" Margin="0,0,0,4"/>
                    <TextBlock Text="🧑‍💼  Employee Entry" Style="{StaticResource H3TextBlockStyle}" Foreground="White"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Cancel_Click"
                        Background="Transparent" BorderThickness="0" Foreground="White" FontSize="18" FontWeight="Light"
                        Cursor="Hand" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ FORM ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0: Section headers -->
                    <RowDefinition Height="Auto"/> <!-- 1: Code / Gender -->
                    <RowDefinition Height="Auto"/> <!-- 2: First / Last name -->
                    <RowDefinition Height="Auto"/> <!-- 3: DOB / DOJ -->
                    <RowDefinition Height="Auto"/> <!-- 4: Department / Designation -->
                    <RowDefinition Height="Auto"/> <!-- 5: Employment Type / Status -->
                    <RowDefinition Height="Auto"/> <!-- 6: Section headers 2 -->
                    <RowDefinition Height="Auto"/> <!-- 7: Phone / PAN -->
                    <RowDefinition Height="Auto"/> <!-- 8: Email / Aadhaar -->
                    <RowDefinition Height="Auto"/> <!-- 9: Address / UAN -->
                    <RowDefinition Height="Auto"/> <!-- 10: EmergencyName / ESIC -->
                    <RowDefinition Height="Auto"/> <!-- 11: EmergencyPhone / BankName -->
                    <RowDefinition Height="Auto"/> <!-- 12: BankAccount / IFSC -->
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                    <TextBlock Text="🧾  PERSONAL &amp; EMPLOYMENT" Style="{StaticResource SectionHeader}"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                    <TextBlock Text="👤  CONTACT" Style="{StaticResource SectionHeader}"/>
                </Border>

                <!-- Row 1 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="EMPLOYEE CODE (auto if blank)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}" Tag="e.g. EMP0001">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmployeeCodeInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding EmployeeCodeError}" Foreground="#EF4444" FontSize="11" Margin="2,2,0,0"
                               Visibility="{Binding IsEmployeeCodeInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="GENDER" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding Gender}" SelectedValuePath="Content">
                        <ComboBoxItem Content="Male"/>
                        <ComboBoxItem Content="Female"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>

                <!-- Row 2 -->
                <StackPanel Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="FIRST NAME *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FirstNameInput" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Tag="Enter first name">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFirstNameInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding FirstNameError}" Foreground="#EF4444" FontSize="11" Margin="2,2,0,0"
                               Visibility="{Binding IsFirstNameInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="LAST NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Tag="Enter last name"/>
                </StackPanel>

                <!-- Row 3 -->
                <StackPanel Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="DATE OF BIRTH" Style="{StaticResource FieldLabel}"/>
                    <DatePicker SelectedDate="{Binding DateOfBirth}"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="DATE OF JOINING *" Style="{StaticResource FieldLabel}"/>
                    <DatePicker SelectedDate="{Binding DateOfJoining}"/>
                </StackPanel>

                <!-- Row 4 -->
                <StackPanel Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="DEPARTMENT" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Departments}" DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectedValue="{Binding DepartmentId}"/>
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="DESIGNATION" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Designations}" DisplayMemberPath="Title" SelectedValuePath="Id"
                              SelectedValue="{Binding DesignationId}"/>
                </StackPanel>

                <!-- Row 5 -->
                <StackPanel Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="EMPLOYMENT TYPE" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding EmploymentTypeOptions}" SelectedItem="{Binding EmploymentType}"/>
                </StackPanel>
                <StackPanel Grid.Row="5" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="STATUS" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
                </StackPanel>

                <!-- Section headers 2 -->
                <Border Grid.Row="6" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,12,0,8" Margin="0,4,0,12">
                    <TextBlock Text="🏦  STATUTORY &amp; BANK" Style="{StaticResource SectionHeader}"/>
                </Border>
                <Border Grid.Row="6" Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,12,0,8" Margin="0,4,0,12">
                    <TextBlock Text="🚨  EMERGENCY CONTACT" Style="{StaticResource SectionHeader}"/>
                </Border>

                <!-- Row 7: Phone/Email moved into contact column earlier; now statutory left, emergency right -->
                <StackPanel Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="PAN" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Pan, UpdateSourceTrigger=PropertyChanged}" Tag="AAAAA9999A"/>
                </StackPanel>
                <StackPanel Grid.Row="7" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="EMERGENCY CONTACT NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EmergencyContactName, UpdateSourceTrigger=PropertyChanged}" Tag="Enter contact name"/>
                </StackPanel>

                <StackPanel Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="AADHAAR" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Aadhaar, UpdateSourceTrigger=PropertyChanged}" Tag="12-digit number"/>
                </StackPanel>
                <StackPanel Grid.Row="8" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="EMERGENCY CONTACT PHONE" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}" Tag="10-digit mobile number"/>
                </StackPanel>

                <StackPanel Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="UAN (Provident Fund)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Uan, UpdateSourceTrigger=PropertyChanged}" Tag="EPFO UAN"/>
                </StackPanel>
                <StackPanel Grid.Row="9" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Tag="10-digit mobile number">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhoneInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding PhoneError}" Foreground="#EF4444" FontSize="11" Margin="2,2,0,0"
                               Visibility="{Binding IsPhoneInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Row="10" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="ESIC NUMBER" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EsicNumber, UpdateSourceTrigger=PropertyChanged}" Tag="ESIC insurance number"/>
                </StackPanel>
                <StackPanel Grid.Row="10" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="EMAIL ID" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Tag="Enter email address">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmailInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding EmailError}" Foreground="#EF4444" FontSize="11" Margin="2,2,0,0"
                               Visibility="{Binding IsEmailInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Row="11" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="BANK NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding BankName, UpdateSourceTrigger=PropertyChanged}" Tag="Enter bank name"/>
                </StackPanel>
                <StackPanel Grid.Row="11" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="ADDRESS" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Tag="Enter address"/>
                </StackPanel>

                <StackPanel Grid.Row="12" Grid.Column="0" Style="{StaticResource FieldStack}">
                    <TextBlock Text="BANK ACCOUNT NUMBER" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding BankAccountNumber, UpdateSourceTrigger=PropertyChanged}" Tag="Enter account number"/>
                </StackPanel>
                <StackPanel Grid.Row="12" Grid.Column="2" Style="{StaticResource FieldStack}">
                    <TextBlock Text="BANK IFSC" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding BankIfsc, UpdateSourceTrigger=PropertyChanged}" Tag="AAAA0999999"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,15,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✕  Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,12,0"/>
                <Button x:Name="SaveButton" Command="{Binding SaveCommand}"
                        Foreground="White" BorderThickness="0"
                        Padding="24,10" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#10B981"/>
                            <Setter Property="Content" Value="💾  Save Employee"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Content" Value="✏️  Update Employee"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</common:EntryDialogWindow>
