<UserControl x:Class="HotelPOS.Views.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="32,20">
            <StackPanel>
                <TextBlock Text="🗓️  Human Resources — Attendance" Style="{StaticResource HeroTextBlockStyle}" Foreground="White"/>
                <TextBlock Text="Mark and review daily attendance for staff."
                           Margin="0,4,0,0" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="White" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── MARK ATTENDANCE PANEL ── -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="MARK ATTENDANCE" Style="{StaticResource FieldLabel}" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="0.7*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="0.7*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="0.7*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="0,0,12,0">
                            <TextBlock Text="DATE" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding SelectedDate}" Width="130"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                            <TextBlock Text="EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} — {1}">
                                                    <Binding Path="EmployeeCode"/>
                                                    <Binding Path="FirstName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                            <TextBlock Text="STATUS" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5" VerticalAlignment="Bottom">
                            <TextBlock Text="CHECK-IN" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CheckInText, UpdateSourceTrigger=PropertyChanged}" Tag="HH:mm"/>
                        </StackPanel>

                        <StackPanel Grid.Column="7" VerticalAlignment="Bottom">
                            <TextBlock Text="CHECK-OUT" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CheckOutText, UpdateSourceTrigger=PropertyChanged}" Tag="HH:mm"/>
                        </StackPanel>

                        <StackPanel Grid.Column="9" VerticalAlignment="Bottom">
                            <TextBlock Text="REMARKS" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" Tag="Optional"/>
                        </StackPanel>

                        <Button Grid.Column="13" Command="{Binding MarkCommand}"
                                Style="{StaticResource PrimaryBtn}" Padding="18,10" VerticalAlignment="Bottom">
                            <TextBlock Text="✔  Mark"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── DATA GRID ── -->
            <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                <DataGrid ItemsSource="{Binding AttendanceRecords}"
                          Style="{StaticResource PremiumGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="EMPLOYEE" Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource GridCellText}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Employee.FirstName"/>
                                                <Binding Path="Employee.LastName"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="*"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <DataGridTextColumn Header="CHECK-IN" Binding="{Binding CheckInTime}" Width="*"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <DataGridTextColumn Header="CHECK-OUT" Binding="{Binding CheckOutTime}" Width="*"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <DataGridTextColumn Header="WORKED HRS" Binding="{Binding WorkedHours}" Width="*"
                                            ElementStyle="{StaticResource GridCellTextRight}"/>

                        <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" Width="1.2*"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <DataGridTemplateColumn Header="ACTIONS" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑 Del"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerBtn}" Padding="12,6" FontSize="12" Margin="6,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
