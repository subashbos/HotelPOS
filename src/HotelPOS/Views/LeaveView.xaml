<UserControl x:Class="HotelPOS.Views.LeaveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="760" d:DesignWidth="1150">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="32,20">
            <StackPanel>
                <TextBlock Text="🌴  Human Resources — Leave" Style="{StaticResource HeroTextBlockStyle}" Foreground="White"/>
                <TextBlock Text="Apply for leave, track balances, and approve or reject requests."
                           Margin="0,4,0,0" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="White" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT: APPLY + BALANCES ══ -->
            <StackPanel Grid.Column="0">
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="APPLY FOR LEAVE" Style="{StaticResource FieldLabel}" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="EMPLOYEE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} — {1}">
                                                <Binding Path="EmployeeCode"/>
                                                <Binding Path="FirstName"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="LEAVE TYPE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding LeaveTypes}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedLeaveType}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FROM DATE" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding FromDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TO DATE" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding ToDate}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="REASON" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" Tag="Optional" Margin="0,0,0,10"/>

                        <Button Command="{Binding ApplyCommand}" Style="{StaticResource PrimaryBtn}" Padding="18,10" HorizontalAlignment="Left">
                            <TextBlock Text="✔  Submit Leave Request"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="LEAVE BALANCE (SELECTED EMPLOYEE)" Style="{StaticResource FieldLabel}" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding Balances}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding LeaveType.Name}" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Grid.Column="1" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} / {1} days">
                                                    <Binding Path="AvailableDays"/>
                                                    <Binding Path="EntitledDays"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══ RIGHT: REQUESTS ══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="APPROVING / REJECTING AS" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Width="220" ItemsSource="{Binding Employees}" SelectedItem="{Binding ApproverEmployee}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FirstName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="REJECTION REASON (used when clicking Reject)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding RejectReasonText, UpdateSourceTrigger=PropertyChanged}" Tag="Optional"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                    <DataGrid ItemsSource="{Binding Requests}"
                              Style="{StaticResource PremiumGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="EMPLOYEE" Width="1.2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource GridCellText}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} {1}">
                                                    <Binding Path="Employee.FirstName"/>
                                                    <Binding Path="Employee.LastName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="TYPE" Binding="{Binding LeaveType.Name}" Width="*"
                                                ElementStyle="{StaticResource GridCellText}"/>

                            <DataGridTextColumn Header="FROM" Binding="{Binding FromDate, StringFormat=dd-MMM-yyyy}" Width="*"
                                                ElementStyle="{StaticResource GridCellText}"/>

                            <DataGridTextColumn Header="TO" Binding="{Binding ToDate, StringFormat=dd-MMM-yyyy}" Width="*"
                                                ElementStyle="{StaticResource GridCellText}"/>

                            <DataGridTextColumn Header="DAYS" Binding="{Binding TotalDays}" Width="0.6*"
                                                ElementStyle="{StaticResource GridCellTextRight}"/>

                            <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="0.8*"
                                                ElementStyle="{StaticResource GridCellTextBold}"/>

                            <DataGridTemplateColumn Header="ACTIONS" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                            <Button Content="✔ Approve"
                                                    Command="{Binding DataContext.ApproveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PrimaryBtn}" Padding="10,6" FontSize="12" Margin="0,0,6,0"/>
                                            <Button Content="✕ Reject"
                                                    Command="{Binding DataContext.RejectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerBtn}" Padding="10,6" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
