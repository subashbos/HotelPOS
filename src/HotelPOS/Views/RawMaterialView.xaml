<UserControl x:Class="HotelPOS.Views.RawMaterialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HotelPOS"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <local:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="32,20">
            <StackPanel>
                <TextBlock Text="🧂  Raw Materials Master" Style="{StaticResource HeroTextBlockStyle}" Foreground="White"/>
                <TextBlock Text="Manage all raw ingredients and their cost per unit. These are used in the Bill of Materials (recipe) for each menu item."
                           Margin="0,4,0,0" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="White" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: DataGrid ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search & New -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔍  " FontSize="16" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <TextBox Width="260" Padding="10,6" FontSize="13"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource AppBackground}"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     ToolTip="Search raw materials"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="＋  New Material" Command="{Binding NewCommand}"
                                Style="{StaticResource PrimaryBtn}" Padding="16,8"/>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="0">
                    <DataGrid ItemsSource="{Binding RawMaterials}"
                              SelectedItem="{Binding SelectedRawMaterial}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource AppBackground}"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70"/>
                            <DataGridTextColumn Header="Cost/Unit (₹)" Binding="{Binding CostPerUnit, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Current Stock" Binding="{Binding CurrentStock, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Min Stock" Binding="{Binding MinStockThreshold, StringFormat=N2}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ── RIGHT: Form Panel ── -->
            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedRawMaterial.Name, TargetNullValue='Add New Raw Material'}"
                                   Style="{StaticResource H3TextBlockStyle}" Margin="0,0,0,20"/>

                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Unit" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Units}" SelectedItem="{Binding Unit}" Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Cost per Unit (₹)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CostPerUnit, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Current Stock" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CurrentStock, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Padding="10,8" Margin="0,0,0,12"/>

                        <TextBlock Text="Min Stock Threshold" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding MinStockThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Padding="10,8" Margin="0,0,0,24"/>

                        <Button Content="💾  Save" Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryBtn}" Height="40" Margin="0,0,0,8"/>
                        <Button Content="🗑  Delete" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerBtn}" Height="40"
                                IsEnabled="{Binding SelectedRawMaterial, Converter={StaticResource NullToBoolConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
