<UserControl x:Class="HotelPOS.Views.PurchaseEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1400">

    <UserControl.Resources>
        <!-- Field Styles matching existing Views -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}"/>
        
        <Style x:Key="InputField" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height"          Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"          Value="0,0,0,16"/>
        </Style>

        <!-- Grid TextBox Style for uniform height and borders -->
        <Style x:Key="GridTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>

        <!-- Grid ComboBox Style for matching height and borders in table cells -->
        <Style x:Key="GridComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>

        <!-- Calculated (read-only) cell: tinted + bold so it reads as "computed", not editable -->
        <Style x:Key="CalculatedCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,0,14,0"/>
            <Setter Property="Background" Value="#1F00A896"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <!-- Delete row icon button: proper hit area, tooltip and hover feedback -->
        <Style x:Key="DeleteRowBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Remove row"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Width="32" Height="32" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1FC0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Main Layout Split -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Background="{DynamicResource HeaderBrush}" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📥  Purchase Entry" Style="{StaticResource HeroTextBlockStyle}" Foreground="White"/>
                    <TextBlock Text="Record supplier purchase invoices, track costs, taxes, and automatically update item inventory stock."
                               Margin="0,4,0,0" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="White" Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ MAIN LAYOUT (30/70 SPLIT) ══ -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>  <!-- Left Form (30%) -->
                <ColumnDefinition Width="7*"/>  <!-- Right Grid/Summary (70%) -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT FORM SIDEBAR (30%) ── -->
            <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource PremiumCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,4,0,4">
                        <TextBlock Text="INVOICE HEADER" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,16"/>

                        <!-- Supplier Search Select -->
                        <TextBlock Text="Supplier Name *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="SupplierComboBox"
                                  ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedSupplier}"
                                  DisplayMemberPath="Name"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  Height="40"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,0,16"/>

                        <!-- Invoice Number -->
                        <TextBlock Text="Invoice Number *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputField}"/>

                        <!-- Purchase Date -->
                        <TextBlock Text="Purchase Date" Style="{StaticResource FieldLabel}"/>
                        <DatePicker SelectedDate="{Binding PurchaseDate}" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Payment Type -->
                        <TextBlock Text="Payment Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox SelectedValue="{Binding PaymentType}" SelectedValuePath="Content" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,16">
                            <ComboBoxItem Content="Cash" IsSelected="True"/>
                            <ComboBoxItem Content="Credit"/>
                            <ComboBoxItem Content="UPI"/>
                        </ComboBox>

                        <!-- Notes -->
                        <TextBlock Text="Notes (Optional)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" Padding="12,8"
                                 Style="{StaticResource InputField}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── RIGHT CONTENT & GRID SECTION (70%) ── -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>     <!-- Table Area -->
                    <RowDefinition Height="Auto"/>  <!-- Sticky Bottom Summary & Actions -->
                </Grid.RowDefinitions>

                <!-- DataGrid Area inside a Premium Card -->
                <Border Style="{StaticResource PremiumCard}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Table Toolbar -->
                            <RowDefinition Height="*"/>     <!-- DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Purchase Items" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Select items from catalog, specify details and observe real-time row totals." Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="➕  Add Row"
                                    Command="{Binding AddRowCommand}"
                                    Style="{StaticResource PrimaryBtn}" Padding="16,8"/>
                        </Grid>

                        <!-- Purchase Items Editable Grid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding PurchaseRows}"
                                  Style="{StaticResource PremiumGrid}"
                                  SelectionMode="Single"
                                  SelectionUnit="CellOrRowHeader"
                                  RowHeight="48"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            
                            <DataGrid.Columns>
                                <!-- Serial No -->
                                <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" IsReadOnly="True" Width="55" HeaderStyle="{StaticResource CenterHeader}" ElementStyle="{StaticResource CenterCell}"/>

                                <!-- Item Dropdown Select -->
                                <DataGridTemplateColumn Header="ITEM NAME" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.CatalogItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="Name"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      Style="{StaticResource GridComboBox}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Quantity -->
                                <DataGridTemplateColumn Header="QTY" Width="85" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                     Style="{StaticResource GridTextBox}" 
                                                     HorizontalContentAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Unit Price -->
                                <DataGridTemplateColumn Header="UNIT PRICE" Width="110" HeaderStyle="{StaticResource RightHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                                     Style="{StaticResource GridTextBox}" 
                                                     HorizontalContentAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Tax (%) -->
                                <DataGridTemplateColumn Header="TAX (%)" Width="90" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding TaxPercentage, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                                     Style="{StaticResource GridTextBox}" 
                                                     HorizontalContentAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Discount -->
                                <DataGridTemplateColumn Header="DISCOUNT" Width="100" HeaderStyle="{StaticResource RightHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                                     Style="{StaticResource GridTextBox}" 
                                                     HorizontalContentAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Total (calculated, not editable) -->
                                <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat=N2}" IsReadOnly="True" Width="110" HeaderStyle="{StaticResource RightHeader}" ElementStyle="{StaticResource CalculatedCell}"/>

                                <!-- Actions delete button -->
                                <DataGridTemplateColumn Width="60" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️"
                                                    Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DeleteRowBtn}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ── STICKY BOTTOM SUMMARY & ACTIONS ── -->
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <!-- Premium Summary Panel -->
                    <Border Background="{DynamicResource HeaderBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Subtotal -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SUBTOTAL" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.65"/>
                                <TextBlock Text="{Binding Subtotal, StringFormat=₹{0:N2}}" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Total Tax -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="TOTAL TAX" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.65"/>
                                <TextBlock Text="{Binding TotalTax, StringFormat=₹{0:N2}}" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Total Discount -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TOTAL DISCOUNT" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.65"/>
                                <TextBlock Text="{Binding TotalDiscount, StringFormat=₹{0:N2}}" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Grand Total (Highlighted) -->
                            <Border Grid.Column="3" Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="14,8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="GRAND TOTAL: " FontSize="12" FontWeight="Bold" Foreground="White" Opacity="0.85" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding GrandTotal, StringFormat=₹{0:N2}}" FontSize="20" FontWeight="Black" Foreground="White" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Save & Cancel Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="❌  Cancel &amp; Reset"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryBtn}"
                                Padding="24,12" FontSize="14" Margin="0,0,24,0"/>

                        <Button Command="{Binding SavePurchaseCommand}"
                                Style="{StaticResource PrimaryBtn}" Content="💾  Save Purchase" Padding="32,12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
