<Window x:Class="HotelPOS.Views.CustomerEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HotelPOS.ViewModels"
        mc:Ignorable="d"
        Title="Customer Entry" Height="560" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Field Label Style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Multiline TextBox Style based on global default -->
        <Style x:Key="MultilineInputField" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource SurfaceBrush}" Margin="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header Banner -->
            <RowDefinition Height="*"/>     <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/>  <!-- Action Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" CornerRadius="15,15,0,0" Padding="24,14" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CREATE / EDIT CUSTOMER" FontSize="10" FontWeight="Bold" Foreground="#14B8A6" Margin="0,0,0,4"/>
                    <TextBlock x:Name="BannerTitle" Text="🧑  Customer Entry" Style="{StaticResource H3TextBlockStyle}" Foreground="White"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Cancel_Click"
                        Background="Transparent" BorderThickness="0" Foreground="White" FontSize="18" FontWeight="Light"
                        Cursor="Hand" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ TWO-COLUMN PERFECTLY ALIGNED FORM GRID ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="32"/>  <!-- High-fidelity spacing gap -->
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Row 0: Section Headers -->
                    <RowDefinition Height="Auto"/>  <!-- Row 1: Name / GSTIN -->
                    <RowDefinition Height="Auto"/>  <!-- Row 2: Phone / (spacer) -->
                    <RowDefinition Height="Auto"/>  <!-- Row 3: Email / (spacer) -->
                    <RowDefinition Height="Auto"/>  <!-- Row 4: Full Width Address -->
                    <RowDefinition Height="Auto"/>  <!-- Row 5: Full Width Notes -->
                </Grid.RowDefinitions>

                <!-- ================= ROW 0: SECTION HEADERS ================= -->
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                    <TextBlock Text="🧾  CONTACT DETAILS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                    <TextBlock Text="🏷️  BILLING DETAILS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>

                <!-- ================= ROW 1: NAME / GSTIN ================= -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="CUSTOMER NAME *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="NameInput" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" GotFocus="Input_GotFocus" Tag="Enter customer name">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNameInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding NameError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsNameInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="GST NUMBER (GSTIN)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Gstin, UpdateSourceTrigger=PropertyChanged}" Tag="Enter GSTIN" CharacterCasing="Upper" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- ================= ROW 2: PHONE ================= -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Tag="10-digit mobile number">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhoneInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding PhoneError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsPhoneInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- ================= ROW 3: EMAIL ================= -->
                <StackPanel Grid.Row="3" Grid.Column="0">
                    <TextBlock Text="EMAIL ID" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Tag="Enter email address">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmailInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding EmailError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsEmailInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- ================= ROW 4: FULL WIDTH ADDRESS ================= -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                    <TextBlock Text="ADDRESS" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MultilineInputField}" Tag="Enter full address here..."/>
                </StackPanel>

                <!-- ================= ROW 5: FULL WIDTH NOTES ================= -->
                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                    <TextBlock Text="NOTES" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MultilineInputField}" Tag="Preferences, allergies, or other notes..."/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ══ ACTION FOOTER ══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,15,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel Button -->
                <Button Content="✕  Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,12,0"/>

                <!-- Save / Update -->
                <Button x:Name="SaveButton" Command="{Binding SaveCommand}"
                        Foreground="White" BorderThickness="0"
                        Padding="24,10" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#10B981"/>
                            <Setter Property="Content" Value="💾  Save Customer"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Content" Value="✏️  Update Customer"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Window>
