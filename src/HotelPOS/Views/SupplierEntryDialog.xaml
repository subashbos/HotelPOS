<Window x:Class="HotelPOS.Views.SupplierEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HotelPOS.ViewModels"
        mc:Ignorable="d"
        Title="Supplier Entry" Height="580" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Field Label Style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Multiline TextBox Style based on global default -->
        <Style x:Key="MultilineInputField" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Right-Aligned Currency Input Style based on global default -->
        <Style x:Key="CurrencyInputField" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header Banner -->
            <RowDefinition Height="*"/>     <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/>  <!-- Action Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <!-- Bonus: Sublabel -->
                    <TextBlock Text="CREATE / EDIT SUPPLIER" FontSize="10" FontWeight="Bold" Foreground="#14B8A6" Margin="0,0,0,4"/>
                    <TextBlock x:Name="BannerTitle" Text="🏢  Supplier Entry" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Cancel_Click" 
                        Background="Transparent" BorderThickness="0" Foreground="White" FontSize="18" FontWeight="Light" 
                        Cursor="Hand" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ TWO-COLUMN PERFECTLY ALIGNED FORM GRID ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="32"/>  <!-- High-fidelity spacing gap -->
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Row 0: Section Headers -->
                    <RowDefinition Height="Auto"/>  <!-- Row 1: Name / City -->
                    <RowDefinition Height="Auto"/>  <!-- Row 2: Contact / State -->
                    <RowDefinition Height="Auto"/>  <!-- Row 3: Phone / Pincode -->
                    <RowDefinition Height="Auto"/>  <!-- Row 4: Email / Opening Balance -->
                    <RowDefinition Height="Auto"/>  <!-- Row 5: GSTIN / Credit Limit -->
                    <RowDefinition Height="Auto"/>  <!-- Row 6: Empty / Payment Terms -->
                    <RowDefinition Height="Auto"/>  <!-- Row 7: Full Width Address -->
                </Grid.RowDefinitions>

                <!-- ================= ROW 0: SECTION HEADERS ================= -->
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                    <TextBlock Text="🧾  BASIC INFORMATION" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                    <TextBlock Text="🏢  ADDITIONAL DETAILS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>

                <!-- ================= ROW 1: SUPPLIER NAME / CITY ================= -->
                <!-- Supplier Name (Auto-Focus, Required, Unique) -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="SUPPLIER NAME *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="NameInput" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" GotFocus="Input_GotFocus" Tag="Enter supplier name">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNameInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding NameError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsNameInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- City -->
                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="CITY" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Tag="Enter city name"/>
                </StackPanel>

                <!-- ================= ROW 2: CONTACT PERSON / STATE ================= -->
                <!-- Contact Person -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="CONTACT PERSON" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" Tag="Enter contact person name"/>
                </StackPanel>

                <!-- State -->
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="STATE" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}" Tag="Enter state name"/>
                </StackPanel>

                <!-- ================= ROW 3: PHONE NUMBER / PINCODE ================= -->
                <!-- Phone Number (Optional, Validated if provided) -->
                <StackPanel Grid.Row="3" Grid.Column="0">
                    <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Tag="10-digit mobile number">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPhoneInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding PhoneError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsPhoneInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Pincode -->
                <StackPanel Grid.Row="3" Grid.Column="2">
                    <TextBlock Text="PINCODE" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged}" Tag="Enter 6-digit pincode"/>
                </StackPanel>

                <!-- ================= ROW 4: EMAIL ID / OPENING BALANCE ================= -->
                <!-- Email ID -->
                <StackPanel Grid.Row="4" Grid.Column="0">
                    <TextBlock Text="EMAIL ID" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Tag="Enter email address">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmailInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="{Binding EmailError}" Foreground="#EF4444" FontSize="11" Margin="2,-6,0,8"
                               Visibility="{Binding IsEmailInvalid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Opening Balance (Currency Prefix, Right-Align, 0.00 Default) -->
                <StackPanel Grid.Row="4" Grid.Column="2">
                    <TextBlock Text="OPENING BALANCE (₹)" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <TextBox Text="{Binding OpeningBalance, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}" 
                                 Style="{StaticResource CurrencyInputField}" Padding="24,8,12,8" Tag="0.00"/>
                        <TextBlock Text="₹" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" 
                                   Foreground="{DynamicResource TextSecondary}" FontSize="13" IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>

                <!-- ================= ROW 5: GST NUMBER / CREDIT LIMIT ================= -->
                <!-- GST Number -->
                <StackPanel Grid.Row="5" Grid.Column="0">
                    <TextBlock Text="GST NUMBER (GSTIN)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Gstin, UpdateSourceTrigger=PropertyChanged}" Tag="Enter GSTIN"/>
                </StackPanel>

                <!-- Credit Limit (Currency Prefix, Right-Align, 50000.00 Default) -->
                <StackPanel Grid.Row="5" Grid.Column="2">
                    <TextBlock Text="CREDIT LIMIT (₹)" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <TextBox Text="{Binding CreditLimit, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}" 
                                 Style="{StaticResource CurrencyInputField}" Padding="24,8,12,8" Tag="50000.00"/>
                        <TextBlock Text="₹" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" 
                                   Foreground="{DynamicResource TextSecondary}" FontSize="13" IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>

                <!-- Payment Terms (Dropdown) -->
                <StackPanel Grid.Row="6" Grid.Column="2">
                    <TextBlock Text="PAYMENT TERMS" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValue="{Binding PaymentTerms}" SelectedValuePath="Content" Margin="0,0,0,10">
                        <ComboBoxItem Content="Cash" IsSelected="True"/>
                        <ComboBoxItem Content="Credit"/>
                        <ComboBoxItem Content="30 Days"/>
                        <ComboBoxItem Content="60 Days"/>
                        <ComboBoxItem Content="90 Days"/>
                    </ComboBox>
                </StackPanel>

                <!-- ================= ROW 7: FULL WIDTH ADDRESS ================= -->
                <!-- Address (Multiline, Full Width) -->
                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                    <TextBlock Text="ADDRESS" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MultilineInputField}" Tag="Enter full address here..."/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ══ ACTION FOOTER ══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel Button -->
                <Button Content="✕  Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,12,0"/>

                <!-- Save / Update (Emerald Green Button with Hover state) -->
                <Button x:Name="SaveButton" Command="{Binding SaveCommand}"
                        Foreground="White" BorderThickness="0"
                        Padding="24,10" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#10B981"/>
                            <Setter Property="Content" Value="💾  Save Supplier"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Content" Value="✏️  Update Supplier"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
