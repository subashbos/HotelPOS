<Window x:Class="HotelPOS.Views.CustomerHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Customer History" Height="620" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource SurfaceBrush}" Margin="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header Banner -->
            <RowDefinition Height="Auto"/>  <!-- Summary Stats -->
            <RowDefinition Height="*"/>     <!-- Orders Grid -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER BANNER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" CornerRadius="15,15,0,0" Padding="24,14" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ORDER HISTORY" FontSize="10" FontWeight="Bold" Foreground="#14B8A6" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CustomerName}" Style="{StaticResource H3TextBlockStyle}" Foreground="White"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Close_Click"
                        Background="Transparent" BorderThickness="0" Foreground="White" FontSize="18" FontWeight="Light"
                        Cursor="Hand" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ SUMMARY STATS ══ -->
        <Grid Grid.Row="1" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource AppBackground}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="TOTAL ORDERS" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding TotalOrders}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource AppBackground}" CornerRadius="8" Padding="12" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="TOTAL SPENT" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding TotalSpent, StringFormat=Rs. {0:N2}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource AppBackground}" CornerRadius="8" Padding="12" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="FIRST ORDER" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding FirstOrderDate, StringFormat=dd MMM yyyy}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="{DynamicResource AppBackground}" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="LAST ORDER" FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock Text="{Binding LastOrderDate, StringFormat=dd MMM yyyy}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ ORDERS GRID ══ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="24,8,24,8">
            <DataGrid ItemsSource="{Binding Orders}"
                      Style="{StaticResource PremiumGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="INVOICE #" Binding="{Binding InvoiceNumber}" Width="1.2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DATE" Binding="{Binding CreatedAt, StringFormat=dd MMM yyyy hh:mm tt}" Width="1.4*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="TYPE" Binding="{Binding OrderType}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="AMOUNT" Binding="{Binding TotalAmount, StringFormat=Rs. {0:N2}}" Width="1.1*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="0,0,15,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" Click="Close_Click" Style="{StaticResource SecondaryBtn}"/>
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Window>
