<UserControl x:Class="HotelPOS.Views.CategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000">



    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Background="{DynamicResource HeaderBrush}" Padding="32,22">
            <StackPanel>
                <TextBlock Text="🏷  Categories" Style="{StaticResource HeroTextBlockStyle}" Foreground="White"/>
                <TextBlock Text="Manage your menu categories to organize items effectively."
                           Margin="0,6,0,0" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="White" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- ══ CONTENT ══ -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Form -->
            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,20">
                                <StackPanel>
                                    <TextBlock x:Name="FormTitle" Text="Add New Category"
                                               Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1" Margin="0,24">
                                <TextBlock Text="CATEGORY NAME" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="NameBox" Margin="0,0,0,16"/>

                                <TextBlock Text="DISPLAY ORDER" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DisplayOrderBox" Margin="0,0,0,16" Text="0" PreviewTextInput="NumberOnly_PreviewTextInput"/>

                                <Border x:Name="StatusBorder" CornerRadius="8" Padding="14,10" Margin="0,8,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="13"/>
                                </Border>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2">
                                <Button x:Name="SubmitButton" Content="＋  Add Category"
                                        Click="Add_Click"
                                        Style="{StaticResource PrimaryBtn}" Padding="0,14" Margin="0,0,0,8"/>
                                
                                <Button x:Name="CancelEditButton" Content="✕  Cancel Edit"
                                        Click="CancelEdit_Click"
                                        Background="Transparent" BorderBrush="{DynamicResource DangerBrush}" 
                                        BorderThickness="1" Foreground="{DynamicResource DangerBrush}"
                                        Padding="0,10" FontWeight="SemiBold" Cursor="Hand" Margin="0,10,0,0"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Border>

            <!-- RIGHT: List -->
            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,16">
                        <TextBlock Text="Existing Categories" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextPrimary}"/>
                    </Border>

                    <DataGrid x:Name="CategoryGrid" Grid.Row="1"
                               Style="{StaticResource PremiumGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="S.NO" Binding="{Binding SNo}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="16,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="CATEGORY NAME" Binding="{Binding Name}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="16,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DISPLAY ORDER" Binding="{Binding DisplayOrder}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="16,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="ACTIONS" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                            <Button Content="✏ Edit" Click="Edit_Click" Tag="{Binding}"
                                                    Style="{StaticResource SecondaryBtn}" 
                                                    Padding="12,6" FontSize="12" Margin="0,0,8,0"/>
                                            <Button Content="🗑 Del" Click="Delete_Click" Tag="{Binding Id}"
                                                    Style="{StaticResource DangerBtn}" 
                                                    Padding="12,6" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
