<UserControl x:Class="HotelPOS.Views.PurchaseReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HotelPOS.Views"
             xmlns:ctrl="clr-namespace:HotelPOS.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource AppBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="Purchase Report" Style="{StaticResource H2TextBlockStyle}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Analyze purchases, vendor expenses, and stock inflow." Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="⟳ Refresh" Command="{Binding ApplyFilterCommand}" 
                        Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Padding="16,8"/>
                
                <Button Content="📥 Export Excel" Click="ExportExcel_Click" 
                        Style="{StaticResource PrimaryBtn}" Background="{DynamicResource SuccessBrush}" Padding="16,8"/>
            </StackPanel>
        </Grid>

        <!-- FILTERS -->
        <Border Grid.Row="1" Style="{StaticResource PremiumCard}" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="DATE RANGE" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <DatePicker SelectedDate="{Binding FilterFrom}" Width="110"/>
                        <TextBlock Text=" to " VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource TextMuted}"/>
                        <DatePicker SelectedDate="{Binding FilterTo}" Width="110"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="SUPPLIER" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" 
                              DisplayMemberPath="Name" Width="160"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock Text="PAYMENT" Style="{StaticResource FieldLabel}"/>
                    <ComboBox SelectedValuePath="Content" SelectedValue="{Binding SelectedPaymentType}" Width="100">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Cash"/>
                        <ComboBoxItem Content="Credit"/>
                        <ComboBoxItem Content="UPI"/>
                        <ComboBoxItem Content="Card"/>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Grid.Column="3" Margin="0,0,16,0">
                    <TextBlock Text="INVOICE NO." Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding InvoiceNoSearch, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,16,0">
                    <TextBlock Text="ITEM NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ItemNameSearch, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                </StackPanel>

                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button Content="Reset" Command="{Binding ResetFilterCommand}" 
                            Style="{StaticResource SecondaryBtn}" BorderThickness="0" Background="Transparent" Padding="12,8" Margin="0,0,8,0"/>
                    <Button Content="Apply Filters" Command="{Binding ApplyFilterCommand}" 
                            Style="{StaticResource PrimaryBtn}" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="2" Style="{StaticResource PremiumCard}" Padding="0" Margin="0,0,0,16">
            <DataGrid x:Name="ReportGrid" ItemsSource="{Binding ReportRows}" Style="{StaticResource PremiumGrid}" IsReadOnly="True" Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SNo}" Width="50" ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding PurchaseDate, StringFormat=dd MMM yyyy HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNumber}" Width="110"/>
                    <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*"/>
                    <DataGridTextColumn Header="Item Name" Binding="{Binding ItemName}" Width="160"/>
                    <DataGridTextColumn Header="Payment" Binding="{Binding PaymentType}" Width="90"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70" ElementStyle="{StaticResource RightCell}" HeaderStyle="{StaticResource RightHeader}"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightCell}" HeaderStyle="{StaticResource RightHeader}"/>
                    <DataGridTextColumn Header="Tax" Binding="{Binding TaxAmount, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightCell}" HeaderStyle="{StaticResource RightHeader}"/>
                    <DataGridTextColumn Header="Discount" Binding="{Binding Discount, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightCell}" HeaderStyle="{StaticResource RightHeader}"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=N2}" Width="100" ElementStyle="{StaticResource RightCell}" HeaderStyle="{StaticResource RightHeader}">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- FOOTER: Pagination & Summary -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pager -->
            <ctrl:PaginationControl x:Name="Pager" Grid.Column="0" VerticalAlignment="Center"/>

            <!-- Summary Block -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="20,12" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Total Purchases" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding TotalPurchasesCount}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Total Qty" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding TotalQuantity}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Total Tax" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding TotalTax, StringFormat=Rs. \{0:N2\}}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Total Discount" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding TotalDiscount, StringFormat=Rs. \{0:N2\}}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Grand Total" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding TotalPurchaseAmount, StringFormat=Rs. \{0:N2\}}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
