                        </StackPanel>

                        <!-- ADMINISTRATION -->
                        <StackPanel x:Name="ModuleAdmin">
                            <TextBlock x:Name="HeaderAdmin" Text="ADMINISTRATION" Style="{StaticResource ModuleHeaderStyle}"/>
                            <Button x:Name="NavSettings" Style="{StaticResource NavBtn}" Click="NavSettings_Click" Tag="Settings" ToolTip="Settings">
                                <Path Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3-1.57-3-3s1.07-3 3-3 3 1.57 3 3-1.07 3-3 3z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="24" Height="24"/>
                            </Button>
                            <Button x:Name="NavRoles" Style="{StaticResource NavBtn}" Click="NavRoles_Click" Tag="Roles &amp; Access" ToolTip="Roles">
                                <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="24" Height="24"/>
                            </Button>
                            <Button x:Name="NavAudit" Style="{StaticResource NavBtn}" Click="NavAudit_Click" Tag="Security Audit" ToolTip="Security Audit">
                                <Path Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 15l-4-4 1.41-1.41L10 13.17l7.59-7.59L19 7l-9 9z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="24" Height="24"/>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- ─── Bottom: Theme + User + Logout ─── -->
                <Border Grid.Row="2" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource SidebarHoverBrush}"
                        BorderThickness="0,1,0,0" Padding="12,12">
                    <Grid>
                        <!-- COMPACT bottom -->
                        <StackPanel x:Name="BottomCompact" HorizontalAlignment="Center">
                            <Button Click="ThemeToggle_Click" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" ToolTip="Toggle Theme" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="🌓" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextMuted}"/>
                            </Button>
                            
                            <!-- Logout (Power Button Icon) -->
                            <Button Click="Logout_Click" Cursor="Hand" ToolTip="Logout"
                                    BorderThickness="0" HorizontalAlignment="Center" Background="Transparent" Margin="0,0,0,10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Width="36" Height="36">
                                            <Path Data="M12 2c-5.52 0-10 4.48-10 10 0 4.75 3.31 8.72 7.75 9.7v-2.07C6.54 18.66 4 15.62 4 12c0-4.41 3.59-8 8-8s8 3.59 8 8c0 3.62-2.54 6.66-5.75 7.63v2.07c4.44-.98 7.75-4.95 7.75-9.7 0-5.52-4.48-10-10-10zm-1 10V4h2v8h-2z"
                                                  Fill="{DynamicResource DangerBrush}" Stretch="Uniform" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Expand Toggle Button (>) in compact mode -->
                            <Button Click="ToggleSidebar_Click" Background="Transparent" Width="28" Height="28"
                                    BorderBrush="{DynamicResource SidebarHoverBrush}" BorderThickness="1" Cursor="Hand" ToolTip="Expand Sidebar" HorizontalAlignment="Center">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                                <TextBlock Text="›" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Button>
                        </StackPanel>

                        <!-- EXPANDED bottom -->
                        <Grid x:Name="BottomExpanded" Visibility="Collapsed" Margin="8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Profile & Theme -->
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/> <!-- Divider -->
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/> <!-- Logout Button -->
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                        Background="{DynamicResource SecondaryBrush}" VerticalAlignment="Center">
                                    <TextBlock x:Name="UserAvatarTextExp" Text="A" Foreground="White"
                                               FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock x:Name="UserNameTextExp" Text="Admin"
                                               Foreground="White" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                                    <TextBlock x:Name="UserRoleText" Text="Administrator"
                                               Foreground="{DynamicResource TextMuted}" FontSize="{StaticResource FontSizeSmall}" Margin="0,1,0,0"/>
                                </StackPanel>
                                
                                <Button Grid.Column="2" Click="ThemeToggle_Click" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Toggle Theme" VerticalAlignment="Center">
                                    <TextBlock Text="🌓" Style="{StaticResource BodyLargeTextBlockStyle}" Foreground="{DynamicResource TextMuted}"/>
                                </Button>
                            </Grid>

                            <!-- Horizontal divider -->
                            <Border Grid.Row="2" Height="1" Background="{DynamicResource SidebarHoverBrush}"/>

                            <!-- Red Logout card -->
                            <Button Grid.Row="4" Click="Logout_Click" Cursor="Hand" ToolTip="Logout"
                                    BorderThickness="0" Background="Transparent" HorizontalAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="12,8">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Path Data="M12 2c-5.52 0-10 4.48-10 10 0 4.75 3.31 8.72 7.75 9.7v-2.07C6.54 18.66 4 15.62 4 12c0-4.41 3.59-8 8-8s8 3.59 8 8c0 3.62-2.54 6.66-5.75 7.63v2.07c4.44-.98 7.75-4.95 7.75-9.7 0-5.52-4.48-10-10-10zm-1 10V4h2v8h-2z"
                                                      Fill="{DynamicResource DangerBrush}" Stretch="Uniform" Width="24" Height="24" VerticalAlignment="Center"/>
                                                <TextBlock Text="Logout" Foreground="{DynamicResource DangerBrush}" Style="{StaticResource BodySmallTextBlockStyle}" FontWeight="{StaticResource FontWeightBold}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══ MAIN AREA WORKSPACE ══ -->
        <!-- Floating rounded card container aligned perfectly with the sidebar -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" 
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" ClipToBounds="True"
                Margin="6,12,12,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Background="{DynamicResource SurfaceBrush}" Height="56"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Workspace" Style="{StaticResource BodySmallTextBlockStyle}"/>
                            <TextBlock Text="  /  " Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource BorderBrush}"/>
                            <TextBlock x:Name="PageTitleText" Text="Dashboard"
                                       Style="{StaticResource BodyTextBlockStyle}" FontWeight="{StaticResource FontWeightBold}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Background="{DynamicResource AppBackground}" CornerRadius="16" Padding="14,7" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBox Width="160" Background="Transparent" BorderThickness="0"
                                             VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Tag="Quick search..."/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="🔔" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,16,0" VerticalAlignment="Center" Cursor="Hand"/>
                            <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource SecondaryBrush}">
                                <TextBlock Text="A" Foreground="White" FontWeight="{StaticResource FontWeightBold}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <ContentControl x:Name="MainContentArea" Grid.Row="1" Focusable="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
