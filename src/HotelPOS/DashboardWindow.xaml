<Window x:Class="HotelPOS.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HotelPOS.Views"
        xmlns:ctrl="clr-namespace:HotelPOS.Controls"
        Title="Hotel POS - Managed Workspace"
        Height="840" Width="1260" MinHeight="660" MinWidth="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded" Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        Icon="/Resources/app_icon.png">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 
            NavBtn Style: Primary category buttons
            Supports path icon in content and label text in Tag.
            Maintains the pixel-perfect teal active state with cyan glowing indicator bar.
        -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="8,1">
                            <!-- Main card background with rounded corners -->
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                <Grid>
                                    <!-- Cyan left edge glowing indicator (Active state) -->
                                    <Border x:Name="ActiveIndicator" Width="4" Height="20" Background="{DynamicResource ActiveIndicatorBrush}" CornerRadius="2"
                                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0" Visibility="Collapsed"/>
 
                                    <Grid x:Name="ContentGrid" Margin="0,0">
                                        <Grid.ColumnDefinitions>
                                            <!-- Column 0 for icon: starts centered in compact mode -->
                                            <ColumnDefinition x:Name="IconColumn" Width="*"/>
                                            <!-- Column 1 for text: starts collapsed in compact mode -->
                                            <ColumnDefinition x:Name="TextColumn" Width="0"/>
                                        </Grid.ColumnDefinitions>
 
                                        <!-- Icon Container -->
                                        <ContentPresenter Grid.Column="0" Content="{TemplateBinding Content}"
                                                          Width="48" Height="48"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
 
                                        <!-- Label Text -->
                                        <TextBlock Grid.Column="1" x:Name="LabelText" Text="{TemplateBinding Tag}"
                                                   Style="{StaticResource BodySmallTextBlockStyle}" FontWeight="{StaticResource FontWeightSemiBold}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Foreground="{TemplateBinding Foreground}" Visibility="Collapsed"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover state: slate-800 background -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Active state (IsEnabled = False): Teal background + Cyan indicator -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SidebarActiveBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Expanded state: show text and set column widths -->
                            <DataTrigger Binding="{Binding Tag, ElementName=SidebarBorder}" Value="expanded">
                                <Setter TargetName="LabelText" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="TextColumn" Property="Width"      Value="*"/>
                                <Setter TargetName="IconColumn" Property="Width"      Value="48"/>
                                <Setter TargetName="ContentGrid" Property="Margin"    Value="12,0"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SubNavBtn Style: For child submenu links under parent categories -->
        <Style x:Key="SubNavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="0,1">
                            <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                       Style="{StaticResource CaptionTextBlockStyle}" FontWeight="{StaticResource FontWeightSemiBold}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource ActiveIndicatorBrush}"/>
                                <Setter TargetName="tb" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ModuleHeaderStyle: For slate-500 uppercase headers in expanded sidebar -->
        <Style x:Key="ModuleHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin" Value="16,12,0,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Width="Auto" allows smooth animation driven by SidebarBorder.Width -->
            <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ FLOATING SIDEBAR ══ -->
        <Border x:Name="SidebarBorder" Background="{DynamicResource SidebarBrush}" Grid.Column="0" Tag="compact" Width="70"
                Margin="12,12,6,12" CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header: logo + toggle -->
                    <RowDefinition Height="*"/>     <!-- Navigation scroll area -->
                    <RowDefinition Height="Auto"/>  <!-- Bottom: theme + user + logout -->
                </Grid.RowDefinitions>

                <!-- ─── Header: App Logo row ─── -->
                <Border BorderBrush="{DynamicResource SidebarHoverBrush}" BorderThickness="0,0,0,1" Padding="12,12">
                    <Grid>
                        <!-- COMPACT: Centered Logo Card -->
                        <Border x:Name="HeaderCompact" CornerRadius="8" Background="White" Width="36" Height="36" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="/Resources/app_icon.png" Width="26" Height="26"
                                   RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- EXPANDED: Logo card + app title + collapse toggle -->
                        <Grid x:Name="HeaderExpanded" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- White Logo Card -->
                            <Border Grid.Column="0" CornerRadius="8" Background="White" Width="36" Height="36">
                                <Image Source="/Resources/app_icon.png" Width="26" Height="26"
                                       RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- App Title -->
                            <TextBlock Grid.Column="1" Text="Hotel POS"
                                       Style="{StaticResource BodyLargeTextBlockStyle}" FontWeight="{StaticResource FontWeightBold}" Foreground="White"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>

                            <!-- Collapse Button (< chevron in small square) -->
                            <Button Grid.Column="2" Click="ToggleSidebar_Click" Background="Transparent" Width="28" Height="28"
                                    BorderBrush="{DynamicResource SidebarHoverBrush}" BorderThickness="1" Cursor="Hand" ToolTip="Collapse Sidebar" VerticalAlignment="Center">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                                <TextBlock Text="‹" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
                <!-- ─── Navigation ─── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                               HorizontalScrollBarVisibility="Disabled" Margin="0,6,0,6">
