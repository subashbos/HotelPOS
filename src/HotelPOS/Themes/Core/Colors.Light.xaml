<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Light Theme Palette -->
    <!-- Colors -->
    <Color x:Key="PrimaryColor">#00A896</Color>
    <Color x:Key="SecondaryColor">#3D5A80</Color>
    <Color x:Key="HeaderColor">#173F5F</Color>
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="WarningColor">#F39C12</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackground" Color="#F3F5F9"/>
    <SolidColorBrush x:Key="SurfaceBrush"   Color="White"/>
    <SolidColorBrush x:Key="PrimaryBrush"   Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="HeaderBrush"    Color="{StaticResource HeaderColor}"/>
    <SolidColorBrush x:Key="TextPrimary"    Color="#1A2533"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#5F6B7A"/>
    <SolidColorBrush x:Key="BorderBrush"    Color="#E0E9F2"/>
    <SolidColorBrush x:Key="DangerBrush"    Color="#C0392B"/>
    <SolidColorBrush x:Key="SuccessBrush"   Color="#27AE60"/>
    <SolidColorBrush x:Key="WarningBrush"   Color="{StaticResource WarningColor}"/>
    
    <!-- Glassmorphism / Transparency effects for Light Mode -->
    <SolidColorBrush x:Key="GlassSurface" Color="#CCFFFFFF"/>
    
    <!-- Sidebar Colors (Dark even in Light mode for contrast) -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="#0D9488"/>
    <SolidColorBrush x:Key="ActiveIndicatorBrush" Color="#0DF0D8"/>
    
    <!-- Analytics Card Gradients -->
    <LinearGradientBrush x:Key="RevenueGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00B4DB" Offset="0"/>
        <GradientStop Color="#0083B0" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="OrdersGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7028E4" Offset="0"/>
        <GradientStop Color="#E5B2CA" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AvgTicketGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#11998E" Offset="0"/>
        <GradientStop Color="#38EF7D" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TopItemGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EB3349" Offset="0"/>
        <GradientStop Color="#F45C43" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ChartBarGradient" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#00C6FB" Offset="0"/>
        <GradientStop Color="#005BEA" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
