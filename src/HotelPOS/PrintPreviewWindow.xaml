<Window x:Class="HotelPOS.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview"
        Height="760" Width="600"
        MinHeight="600" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded"
        WindowState="Maximized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Icon="/Resources/app_icon.png">

    <Window.Resources>
        <Style x:Key="FormatToggleButton" TargetType="RadioButton">
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSizeBodySmall}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AppBackground}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resources/app_icon.png" Width="24" Height="24" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Receipt Preview" Style="{StaticResource H3TextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Format toggles -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Layout:" Style="{StaticResource BodySmallTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton x:Name="ThermalToggle" Content="Thermal (80mm)" Style="{StaticResource FormatToggleButton}" GroupName="LayoutFormat" Checked="Format_Checked"/>
                    <RadioButton x:Name="A4Toggle" Content="Standard (A4)" Style="{StaticResource FormatToggleButton}" GroupName="LayoutFormat" Margin="8,0,0,0" Checked="Format_Checked"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DOCUMENT PREVIEWER -->
        <FlowDocumentScrollViewer x:Name="DocViewer" Grid.Row="1" Margin="0" Background="{DynamicResource AppBackground}" VerticalScrollBarVisibility="Auto"/>

        <!-- BOTTOM ACTION BAR -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16">
            <Grid>
                <Button Content="✕  Cancel" HorizontalAlignment="Left" Style="{StaticResource SecondaryBtn}" Click="Cancel_Click"/>
                <Button Content="🖨  Print Receipt" HorizontalAlignment="Right" Style="{StaticResource PrimaryBtn}" Click="Print_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
