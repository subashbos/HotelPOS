<Window x:Class="HotelPOS.AddItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Menu Item Management — Hotel POS"
        Height="650" Width="500"
        MinHeight="650" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded"
        Icon="/Resources/app_icon.png">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,10"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Foreground"     Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin"         Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/app_icon.png" Width="32" Height="32" Margin="0,0,16,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Menu Item Management"
                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Update your menu catalog details."
                                   Margin="0,4,0,0" FontSize="13" Foreground="#BDD5E7"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Close_Click" 
                        Background="Transparent" Foreground="White" FontSize="20" FontWeight="Normal" 
                        Padding="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="32,24">
                <StackPanel>
                    <Border Background="{DynamicResource SurfaceBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" 
                            Padding="28" 
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock x:Name="FormTitle" Text="Add New Item" 
                                       FontSize="20" FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Fill in the details to save a menu item." 
                                       FontSize="13" Foreground="{DynamicResource TextMuted}" 
                                       Margin="0,0,0,24"/>

                            <TextBlock Text="ITEM NAME" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="ItemNameBox" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel>
                                    <TextBlock Text="BASE PRICE (RS.)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="ItemPriceBox"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="TAX PERCENTAGE (%)" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="TaxCombo" Padding="12,10" FontSize="14"
                                              Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimary}">
                                        <ComboBoxItem Content="0% GST" Tag="0"/>
                                        <ComboBoxItem Content="5% GST" Tag="5"/>
                                        <ComboBoxItem Content="12% GST" Tag="12"/>
                                        <ComboBoxItem Content="18% GST" Tag="18"/>
                                        <ComboBoxItem Content="28% GST" Tag="28"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="CATEGORY" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="ItemCategoryCombo" DisplayMemberPath="Name" SelectedValuePath="Id"
                                      Padding="12,10" FontSize="14" Margin="0,0,0,16"
                                      Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Text="BARCODE / SKU" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="BarcodeBox" Margin="0,0,0,16"/>

                            <CheckBox x:Name="TrackStockCheck" Content="Track Inventory" 
                                      FontSize="14" Margin="0,8,0,16" VerticalContentAlignment="Center"
                                      Foreground="{DynamicResource TextPrimary}"/>

                            <StackPanel x:Name="StockPanel" Visibility="Visible">
                                <TextBlock Text="INITIAL STOCK QUANTITY" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="StockQuantityBox" Margin="0,0,0,16"/>
                            </StackPanel>

                            <Border x:Name="StatusBorder" CornerRadius="8" Padding="14,10" Margin="0,8,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="13"/>
                            </Border>

                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="SubmitBtn" Content="💾  Save Menu Item" Click="AddItem_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
