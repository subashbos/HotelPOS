<Application x:Class="HotelPOS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HotelPOS">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ToastNotifications.Messages;component/Themes/Default.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:IdToEnabledConverter x:Key="IdToEnabledConverter"/>
            <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <local:StockToColorConverter x:Key="StockToColorConverter"/>
            <local:StockToColorMultiConverter x:Key="StockToColorMultiConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
