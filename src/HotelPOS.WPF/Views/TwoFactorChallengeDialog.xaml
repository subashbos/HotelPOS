<Window x:Class="HotelPOS.Views.TwoFactorChallengeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Two-Factor Authentication" Height="260" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <StackPanel Margin="28">
        <TextBlock x:Name="TitleText" Style="{StaticResource H3TextBlockStyle}" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
        <TextBlock Text="Enter the 6-digit code from your authenticator app." Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <TextBlock Text="AUTHENTICATION CODE" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="CodeBox" Margin="0,0,0,20" MaxLength="6"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,10,0"/>
            <Button Content="Verify" Click="Verify_Click" Style="{StaticResource PrimaryBtn}" Padding="16,8"/>
        </StackPanel>
    </StackPanel>
</Window>
